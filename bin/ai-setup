#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)/lib/common.sh"

dry_run=0
heal_only=0
install_shell_path=0
hcom_hooks_action=""
shims_action=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --dry-run) dry_run=1 ;;
    --heal-only) heal_only=1 ;;
    --shell-path) install_shell_path=1 ;;
    --hcom-hooks)
      shift
      case "${1:-}" in
        install|remove|status) hcom_hooks_action="$1" ;;
        "")
          log_error "--hcom-hooks requires one of: install, remove, status"
          exit 2
          ;;
        *)
          log_error "unknown --hcom-hooks action: $1"
          exit 2
          ;;
      esac
      ;;
    --shims)
      shift
      case "${1:-}" in
        install|remove|status) shims_action="$1" ;;
        "")
          log_error "--shims requires one of: install, remove, status"
          exit 2
          ;;
        *)
          log_error "unknown --shims action: $1"
          exit 2
          ;;
      esac
      ;;
    -h|--help)
      cat <<'USAGE'
Usage: ai-setup [--dry-run] [--heal-only] [--shell-path]
       ai-setup [--dry-run] --hcom-hooks install|remove|status
       ai-setup [--dry-run] --shims install|remove|status

Installs symlinks from live agent config paths into this repo.
--heal-only only repairs missing, broken, or wrong symlinks and never backs up
real files or directories.
--shell-path installs a managed PATH block into ~/.zshrc or ~/.bashrc.
--hcom-hooks manages global hcom hooks for Claude and Codex only when explicitly
requested. Hooks are launch-managed by hcom itself; ai-setup is the durable/manual
install, remove, and status layer rather than a default setup side effect.
--shims manages the mise conf.d PATH activation file for herder's claude/codex
PATH shims. It only puts the shim directory on PATH; tool permission defaults
remain a manual user choice.
USAGE
      exit 0
      ;;
    *)
      log_error "unknown argument: $1"
      exit 2
      ;;
  esac
  shift
done

run() {
  if [ "$dry_run" -eq 1 ]; then
    printf 'DRY %s\n' "$*"
  else
    "$@"
  fi
}

install_link() {
  local src="$1"
  local dst="$2"
  local parent
  local backup

  [ -e "$src" ] || {
    log_info "skip missing source: $src"
    return
  }

  parent="$(dirname "$dst")"

  if [ ! -d "$parent" ]; then
    if [ "$heal_only" -eq 1 ]; then
      log_warn "skip missing parent in heal mode: $parent"
      return
    fi
    run mkdir -p "$parent"
  fi

  if [ -L "$dst" ]; then
    if symlink_points_to "$dst" "$src"; then
      log_info "link already ok: $dst"
      return
    fi

    log_info "replace symlink: $dst"
    run rm "$dst"
    run ln -s "$(abs_path "$src")" "$dst"
    return
  fi

  if [ -e "$dst" ]; then
    if [ "$heal_only" -eq 1 ]; then
      log_warn "collision in heal mode, leaving untouched: $dst"
      return
    fi

    if [ "$dry_run" -eq 1 ]; then
      log_info "would back up collision: $dst"
    else
      backup="$(backup_target "$dst")"
      log_info "backed up $dst -> $backup"
    fi
    run ln -s "$(abs_path "$src")" "$dst"
    return
  fi

  log_info "create link: $dst -> $src"
  run ln -s "$(abs_path "$src")" "$dst"
}

install_portable_links() {
  local spec
  local src_rel
  local dst

  while IFS= read -r spec; do
    src_rel="${spec%%|*}"
    dst="${spec#*|}"
    install_link "$AI_CONFIG_ROOT/$src_rel" "$dst"
  done < <(portable_link_specs)
}

install_skill_links() {
  local spec
  local agent
  local config_home
  local root
  local skill

  while IFS='|' read -r agent config_home root; do
    if [ ! -d "$config_home" ]; then
      case "$agent" in
        claude|codex)
          [ "$heal_only" -eq 1 ] && continue
          run mkdir -p "$config_home"
          ;;
        *)
          continue
          ;;
      esac
    fi

    if [ ! -d "$root" ]; then
      [ "$heal_only" -eq 1 ] && continue
      run mkdir -p "$root"
    fi

    while IFS= read -r skill; do
      install_link "$AI_CONFIG_ROOT/skills/$skill" "$root/$skill"
    done < <(repo_skill_names)
  done < <(skill_root_specs)
}

shell_path_block() {
  cat <<EOF
# >>> ai-config >>>
AI_CONFIG_HOME="$AI_CONFIG_ROOT"
case ":\$PATH:" in
  *":\$AI_CONFIG_HOME/bin:"*) ;;
  *) export PATH="\$AI_CONFIG_HOME/bin:\$PATH" ;;
esac
# <<< ai-config <<<
EOF
}

shell_rc_file() {
  if [ -n "${SHELL:-}" ]; then
    case "$(basename "$SHELL")" in
      zsh) printf '%s\n' "$HOME/.zshrc"; return ;;
      bash) printf '%s\n' "$HOME/.bashrc"; return ;;
    esac
  fi

  if [ -f "$HOME/.zshrc" ]; then
    printf '%s\n' "$HOME/.zshrc"
  else
    printf '%s\n' "$HOME/.bashrc"
  fi
}

install_shell_path_block() {
  local rc
  local tmp

  rc="$(shell_rc_file)"

  if [ -f "$rc" ] && grep -q '^# >>> ai-config >>>$' "$rc"; then
    log_info "shell PATH block already present: $rc"
    return
  fi

  if [ "$dry_run" -eq 1 ]; then
    log_info "would append ai-config PATH block to $rc:"
    shell_path_block
    return
  fi

  mkdir -p "$(dirname "$rc")"
  touch "$rc"
  tmp="$(mktemp)"
  {
    cat "$rc"
    printf '\n'
    shell_path_block
  } > "$tmp"
  mv "$tmp" "$rc"
  log_info "installed ai-config PATH block in $rc"
}

if [ -n "$hcom_hooks_action" ]; then
  source "$AI_CONFIG_ROOT/lib/hcom-hooks.sh"
  hcom_hooks_main "$hcom_hooks_action"
  log_info "ai-setup hcom hooks $hcom_hooks_action complete"
  exit 0
fi

if [ -n "$shims_action" ]; then
  source "$AI_CONFIG_ROOT/lib/shims-install.sh"
  shims_main "$shims_action"
  log_info "ai-setup shims $shims_action complete"
  exit 0
fi

install_portable_links
install_skill_links

if [ "$install_shell_path" -eq 1 ]; then
  install_shell_path_block
else
  log_info "PATH not modified; run ai-setup --shell-path to add $AI_CONFIG_ROOT/bin to your shell"
fi

log_info "ai-setup complete"
