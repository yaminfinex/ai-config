#!/usr/bin/env python3
"""Localhost HTTP service that opens VS Code Remote-SSH at a given path.

Receives GET /open?token=<t>&path=<p> on 127.0.0.1, validates the token
and path, then asks macOS LaunchServices to open
`vscode://vscode-remote/ssh-remote+$VSC_REMOTE_HOST<path>`.

Using the URL scheme (vs `code --remote ...` directly) routes the request
through the already-running, Aqua-attached VS Code instance — no
launchd-spawned Electron launcher, no stranded Dock icon per call.

Config: ~/.config/vsc-opener/config (KEY=value lines).
"""
from __future__ import annotations

import os
import shlex
import subprocess
import sys
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from urllib.parse import parse_qs, quote, urlparse

CONFIG_PATH = Path.home() / ".config" / "vsc-opener" / "config"


def load_config(path: Path) -> dict[str, str]:
    cfg: dict[str, str] = {}
    if not path.exists():
        sys.exit(f"vsc-opener: config not found: {path}")
    for raw in path.read_text().splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        key = key.strip()
        if key.startswith("export "):
            key = key[len("export "):].strip()
        value = value.strip()
        if len(value) >= 2 and value[0] == value[-1] and value[0] in ("'", '"'):
            value = value[1:-1]
        cfg[key] = value
    return cfg


CFG = load_config(CONFIG_PATH)
TOKEN = CFG.get("VSC_OPEN_TOKEN", "")
PORT = int(CFG.get("VSC_OPEN_PORT", "36221"))
HOST = CFG.get("VSC_REMOTE_HOST", "")
ALLOWED_PREFIX = CFG.get("VSC_ALLOWED_PREFIX", "").rstrip("/")

if not TOKEN:
    sys.exit("vsc-opener: VSC_OPEN_TOKEN missing in config")
if not HOST:
    sys.exit("vsc-opener: VSC_REMOTE_HOST missing in config")


def log(msg: str) -> None:
    print(f"vsc-opener: {msg}", file=sys.stderr, flush=True)


class Handler(BaseHTTPRequestHandler):
    def do_GET(self) -> None:  # noqa: N802
        parsed = urlparse(self.path)
        if parsed.path != "/open":
            self.send_error(404, "not found")
            return
        q = parse_qs(parsed.query)
        if q.get("token", [""])[0] != TOKEN:
            self.send_error(403, "bad token")
            return
        path = q.get("path", [""])[0]
        if not path.startswith("/"):
            self.send_error(400, "path must be absolute")
            return
        if ALLOWED_PREFIX and not path.startswith(ALLOWED_PREFIX + "/") and path != ALLOWED_PREFIX:
            self.send_error(403, f"path outside {ALLOWED_PREFIX}")
            return
        url = f"vscode://vscode-remote/ssh-remote+{HOST}{quote(path)}"
        cmd = ["open", url]
        log(f"open {shlex.join(cmd)}")
        try:
            subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except FileNotFoundError:
            self.send_error(500, "macOS `open` binary not found")
            return
        self.send_response(204)
        self.end_headers()

    def log_message(self, fmt: str, *args) -> None:  # noqa: A003
        log(fmt % args)


def main() -> None:
    addr = ("127.0.0.1", PORT)
    log(f"listening on http://{addr[0]}:{addr[1]} -> ssh-remote+{HOST}")
    ThreadingHTTPServer(addr, Handler).serve_forever()


if __name__ == "__main__":
    main()
