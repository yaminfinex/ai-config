#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)/lib/common.sh"

quick=0
strict=0

for arg in "$@"; do
  case "$arg" in
    --quick) quick=1 ;;
    --strict) strict=1 ;;
    -h|--help)
      cat <<'USAGE'
Usage: ai-doctor [--quick] [--strict]

Checks ai-config repository health, link drift, local-only skills, secrets,
machine-specific absolute home paths, Claude config divergence, and Grok
credential/home/PATH-resolution drift. It also warns when the current shell carries
managed-agent identity that makes direct vendor CLI probes unsafe. Findings are
reported only; Grok state is never repaired automatically.

--quick skips network freshness checks. --strict fails on repository-health
warnings; the situational identity-bearing-shell nudge remains warning-tier rc 0.
USAGE
      exit 0
      ;;
    *)
      log_error "unknown argument: $arg"
      exit 2
      ;;
  esac
done

errors=0
warnings=0
strict_exempt_warnings=0

warn() {
  warnings=$((warnings + 1))
  log_warn "$*"
}

warn_strict_exempt() {
  warnings=$((warnings + 1))
  strict_exempt_warnings=$((strict_exempt_warnings + 1))
  log_warn "$*"
}

err() {
  errors=$((errors + 1))
  log_error "$*"
}

check_git() {
  local branch_status
  local upstream

  if ! git -C "$AI_CONFIG_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    err "$AI_CONFIG_ROOT is not a Git repository"
    return
  fi

  branch_status="$(git -C "$AI_CONFIG_ROOT" status --short --branch)"
  printf '%s\n' "$branch_status"

  if git_dirty; then
    warn "working tree has uncommitted changes"
  fi

  if ! upstream="$(git -C "$AI_CONFIG_ROOT" rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null)"; then
    warn "current branch has no upstream remote"
  else
    log_info "upstream: $upstream"
  fi
}

check_portable_links() {
  local spec
  local src_rel
  local dst
  local src

  while IFS= read -r spec; do
    src_rel="${spec%%|*}"
    dst="${spec#*|}"
    src="$AI_CONFIG_ROOT/$src_rel"

    [ -e "$src" ] || continue

    if [ -L "$dst" ]; then
      if symlink_points_to "$dst" "$src"; then
        [ "$quick" -eq 1 ] || log_info "link ok: $dst"
      else
        warn "link points elsewhere: $dst -> $(readlink "$dst")"
      fi
    elif [ -e "$dst" ]; then
      warn "collision: $dst exists and is not a symlink"
    else
      warn "missing link: $dst -> $src"
    fi
  done < <(portable_link_specs)
}

check_skill_links() {
  local spec
  local agent
  local config_home
  local root
  local skill
  local src
  local dst

  while IFS='|' read -r agent config_home root; do
    [ -d "$config_home" ] || continue

    while IFS= read -r skill; do
      src="$AI_CONFIG_ROOT/skills/$skill"
      dst="$root/$skill"

      if [ -L "$dst" ]; then
        if symlink_points_to "$dst" "$src"; then
          [ "$quick" -eq 1 ] || log_info "skill link ok: $agent:$skill"
        else
          warn "skill link points elsewhere: $dst -> $(readlink "$dst")"
        fi
      elif [ -e "$dst" ]; then
        warn "skill collision: $dst exists and is not a symlink"
      else
        warn "missing skill link: $dst -> $src"
      fi
    done < <(repo_skill_names)
  done < <(skill_root_specs)
}

check_unharvested_live_skills() {
  local spec
  local agent
  local config_home
  local root
  local child
  local name
  local real_child
  local seen_children=()
  local seen_child
  local already_seen

  while IFS='|' read -r agent config_home root; do
    [ -d "$root" ] || continue

    while IFS= read -r child; do
      real_child="$(abs_path "$child")"
      already_seen=0
      if [ "${#seen_children[@]}" -gt 0 ]; then
        for seen_child in "${seen_children[@]}"; do
          if [ "$seen_child" = "$real_child" ]; then
            already_seen=1
            break
          fi
        done
      fi

      [ "$already_seen" -eq 1 ] && continue
      seen_children+=("$real_child")

      name="$(basename "$child")"
      case "$agent:$name" in
        project-*:ai-config-bootstrap) continue ;;
      esac

      is_ignored_live_skill_name "$name" && continue
      repo_skill_exists "$name" && continue
      [ -f "$child/SKILL.md" ] || continue

      warn "unharvested local skill in $agent: $child"
    done < <(find "$root" -mindepth 1 -maxdepth 1 \( -type d -o -type l \) -print 2>/dev/null)
  done < <(
    skill_root_specs
    project_skill_root_specs
  )
}

check_secret_scan() {
  local paths=()
  local findings

  while IFS= read -r path; do
    paths+=("$path")
  done < <(existing_scan_paths "${PORTABLE_SCAN_PATHS[@]}")

  findings="$(scan_secret_regex_paths "${paths[@]}")"
  if [ -n "$findings" ]; then
    err "possible secret found:"
    printf '%s\n' "$findings" >&2
  fi
}

print_statusline_snippet() {
  cat >&2 <<'SNIPPET'
  merge this into ~/.claude/settings.json:
    "statusLine": {
      "command": "$HOME/.claude/statusline.sh",
      "type": "command"
    }
SNIPPET
}

check_claude_statusline_settings() {
  local settings="$HOME/.claude/settings.json"
  local expected="$HOME/.claude/statusline.sh"
  local command

  [ -f "$settings" ] || {
    warn "claude settings missing: $settings"
    print_statusline_snippet
    return
  }

  if ! command -v jq >/dev/null 2>&1; then
    warn "jq not installed; skipping statusLine check in $settings"
    return
  fi

  command="$(jq -r '.statusLine.command // ""' "$settings" 2>/dev/null)"

  case "$command" in
    "")
      warn "statusLine.command not set in $settings"
      print_statusline_snippet
      ;;
    "$expected"|'$HOME/.claude/statusline.sh'|"~/.claude/statusline.sh")
      [ "$quick" -eq 1 ] || log_info "statusLine ok: $command"
      ;;
    *)
      warn "statusLine.command in $settings points elsewhere: $command (expected $expected)"
      print_statusline_snippet
      ;;
  esac
}

check_claude_shared_settings() {
  local shared="$AI_CONFIG_ROOT/claude/settings.shared.json"

  [ -f "$shared" ] || return 0

  if ! command -v jq >/dev/null 2>&1; then
    warn "jq not installed; skipping shared settings check"
    return
  fi

  source "$AI_CONFIG_ROOT/lib/claude-settings.sh"

  jq -e . "$shared" >/dev/null 2>&1 || {
    err "shared settings fragment is not valid JSON: $shared"
    return
  }

  claude_settings_live_valid || {
    warn "live claude settings are not valid JSON: $CLAUDE_SETTINGS_LIVE"
    return
  }

  if claude_settings_in_sync; then
    [ "$quick" -eq 1 ] || log_info "claude shared settings ok: $CLAUDE_SETTINGS_LIVE"
  else
    warn "claude settings missing shared fragment keys; run bin/ai-setup"
  fi
}

print_claude_config_divergence_options() {
  cat >&2 <<'OPTIONS'
  pinned non-default-bus claude sessions read ~/.claude/.claude.json; plain sessions
  read ~/.claude.json — while they differ the two run with different
  identity/config state. Your call (ai-doctor never fixes this itself):
    re-align: cp ~/.claude.json ~/.claude/.claude.json
    delete:   rm ~/.claude/.claude.json    # safe: next pinned launch re-seeds it
OPTIONS
}

check_claude_config_divergence() {
  local base="$HOME/.claude.json"
  local pinned="$HOME/.claude/.claude.json"

  [ -f "$base" ] || return 0
  [ -f "$pinned" ] || return 0

  if cmp -s "$base" "$pinned"; then
    [ "$quick" -eq 1 ] || log_info "claude config copies identical: $pinned"
    return 0
  fi

  warn "claude config divergence: $pinned differs from $base"
  print_claude_config_divergence_options
}

check_portability_scan() {
  local paths=()
  local findings

  while IFS= read -r path; do
    paths+=("$path")
  done < <(existing_scan_paths "${PORTABLE_SCAN_PATHS[@]}")

  findings="$(scan_portability_paths "${paths[@]}")"
  if [ -n "$findings" ]; then
    err "absolute home path found in portable file:"
    printf '%s\n' "$findings" >&2
  fi
}

check_mise_path() {
  source "$AI_CONFIG_ROOT/lib/mise-path.sh"

  local file
  local bin_dir
  local shims_dir
  local configured
  local count
  local tool
  local expected
  local resolution

  if mise_available; then
    [ "$quick" -eq 1 ] || log_info "mise present"
  else
    err "mise is required; install mise, then run bin/ai-setup"
    return
  fi

  file="$(mise_path_config_file)"
  bin_dir="$(mise_bin_dir)"
  shims_dir="$(mise_shims_dir)"

  if [ ! -e "$file" ]; then
    warn "ai-config mise PATH config missing; run bin/ai-setup"
    return
  fi

  if ! mise_file_is_ours "$file"; then
    warn "ai-config mise PATH config exists but is not managed by ai-config: $file"
    return
  fi

  configured="$(mise_configured_paths "$file" || true)"
  if ! printf '%s\n' "$configured" | grep -Fqx "$bin_dir"; then
    warn "ai-config mise PATH config missing bin dir: $bin_dir"
  fi
  if ! printf '%s\n' "$configured" | grep -Fqx "$shims_dir"; then
    warn "ai-config mise PATH config missing herder shim dir: $shims_dir"
  fi

  count="$(mise_path_count "$bin_dir")"
  if [ "$count" != "1" ]; then
    warn "ai-config bin dir should appear on PATH exactly once; found $count: $bin_dir"
  fi
  count="$(mise_path_count "$shims_dir")"
  if [ "$count" != "1" ]; then
    warn "herder shim dir should appear on PATH exactly once; found $count: $shims_dir"
  fi

  for tool in herder claude codex grok; do
    case "$tool" in
      herder) expected="$bin_dir/herder" ;;
      claude|codex|grok) expected="$shims_dir/$tool" ;;
    esac
    resolution="$(mise_tool_resolution_message "$tool" "$expected")"
    case "$resolution" in
      "$tool: expected first") [ "$quick" -eq 1 ] || log_info "$resolution" ;;
      *) warn "$resolution" ;;
    esac
  done
}

check_grok_family() {
  source "$AI_CONFIG_ROOT/lib/grok-health.sh"

  local configured_home="${GROK_HOME:-}"
  local vendor_binary

  if [ ! -x "$AI_CONFIG_ROOT/tools/herder/shims/grok" ]; then
    err "Grok PATH shim missing or not executable: $AI_CONFIG_ROOT/tools/herder/shims/grok; restore the checkout and rerun bin/ai-setup"
  fi

  if [ -z "${XAI_API_KEY:-}" ]; then
    warn "Grok credential precondition missing: XAI_API_KEY is absent or empty in this environment; export it from a login-shell profile such as \$HOME/.profile, then verify in a fresh herder pane"
  fi

  if [ -n "$configured_home" ]; then
    warn "GROK_HOME is set to $configured_home, but herder launches deliberately unset it so Grok uses the vendor default $HOME/.grok"
  fi

  vendor_binary="$(grok_vendor_on_path || true)"
  if [ -z "$vendor_binary" ]; then
    warn "no Grok vendor binary found on PATH after herder shims; install Grok Build before launch"
  else
    [ "$quick" -eq 1 ] || log_info "Grok vendor binary resolved after herder PATH shims (not executed): $vendor_binary"
  fi
}

check_identity_bearing_shell() {
  local key
  local present=()

  for key in HCOM_PROCESS_ID HCOM_INSTANCE_NAME HCOM_SESSION_ID HERDER_GUID HERDR_PANE_ID; do
    if [ -n "${!key:-}" ]; then
      present+=("$key")
    fi
  done
  [ "${#present[@]}" -gt 0 ] || return 0

  # This is a situational launch-safety nudge, not repository health. Managed
  # agent shells carry these values by design, so --strict must not make every
  # doctor run inside a seat permanently red.
  warn_strict_exempt "current shell carries managed-agent identity (${present[*]}); never invoke a vendor agent CLI directly here — use herder, or run probes under env -i with an isolated HOME/state and no HCOM_*/HERDER_*/HERDR_* values"
}

check_git
check_portable_links
check_skill_links
check_unharvested_live_skills
check_claude_statusline_settings
check_claude_shared_settings
check_claude_config_divergence
check_mise_path
check_grok_family
check_identity_bearing_shell
check_secret_scan
check_portability_scan

if [ "$errors" -gt 0 ]; then
  log_error "ai-doctor found $errors error(s) and $warnings warning(s)"
  exit 1
fi

if [ "$warnings" -gt 0 ]; then
  log_warn "ai-doctor found $warnings warning(s)"
  [ "$strict" -eq 1 ] && [ "$warnings" -gt "$strict_exempt_warnings" ] && exit 1
  exit 0
fi

log_info "ai-doctor ok"
