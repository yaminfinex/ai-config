#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)/lib/common.sh"

quick=0
strict=0

for arg in "$@"; do
  case "$arg" in
    --quick) quick=1 ;;
    --strict) strict=1 ;;
    -h|--help)
      cat <<'USAGE'
Usage: ai-doctor [--quick] [--strict]

Checks ai-config repository health, link drift, local-only skills, secrets,
machine-specific absolute home paths, and vendored cmux reference freshness.

--quick skips network freshness checks.
USAGE
      exit 0
      ;;
    *)
      log_error "unknown argument: $arg"
      exit 2
      ;;
  esac
done

errors=0
warnings=0

warn() {
  warnings=$((warnings + 1))
  log_warn "$*"
}

err() {
  errors=$((errors + 1))
  log_error "$*"
}

check_git() {
  local branch_status
  local upstream

  if ! git -C "$AI_CONFIG_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    err "$AI_CONFIG_ROOT is not a Git repository"
    return
  fi

  branch_status="$(git -C "$AI_CONFIG_ROOT" status --short --branch)"
  printf '%s\n' "$branch_status"

  if git_dirty; then
    warn "working tree has uncommitted changes"
  fi

  if ! upstream="$(git -C "$AI_CONFIG_ROOT" rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null)"; then
    warn "current branch has no upstream remote"
  else
    log_info "upstream: $upstream"
  fi
}

check_portable_links() {
  local spec
  local src_rel
  local dst
  local src

  while IFS= read -r spec; do
    src_rel="${spec%%|*}"
    dst="${spec#*|}"
    src="$AI_CONFIG_ROOT/$src_rel"

    [ -e "$src" ] || continue

    if [ -L "$dst" ]; then
      if symlink_points_to "$dst" "$src"; then
        [ "$quick" -eq 1 ] || log_info "link ok: $dst"
      else
        warn "link points elsewhere: $dst -> $(readlink "$dst")"
      fi
    elif [ -e "$dst" ]; then
      warn "collision: $dst exists and is not a symlink"
    else
      warn "missing link: $dst -> $src"
    fi
  done < <(portable_link_specs)
}

check_skill_links() {
  local spec
  local agent
  local config_home
  local root
  local skill
  local src
  local dst

  while IFS='|' read -r agent config_home root; do
    [ -d "$config_home" ] || continue

    while IFS= read -r skill; do
      src="$AI_CONFIG_ROOT/skills/$skill"
      dst="$root/$skill"

      if [ -L "$dst" ]; then
        if symlink_points_to "$dst" "$src"; then
          [ "$quick" -eq 1 ] || log_info "skill link ok: $agent:$skill"
        else
          warn "skill link points elsewhere: $dst -> $(readlink "$dst")"
        fi
      elif [ -e "$dst" ]; then
        warn "skill collision: $dst exists and is not a symlink"
      else
        warn "missing skill link: $dst -> $src"
      fi
    done < <(repo_skill_names)
  done < <(skill_root_specs)
}

check_unharvested_live_skills() {
  local spec
  local agent
  local config_home
  local root
  local child
  local name
  local real_child
  local seen_children=()
  local seen_child
  local already_seen

  while IFS='|' read -r agent config_home root; do
    [ -d "$root" ] || continue

    while IFS= read -r child; do
      real_child="$(abs_path "$child")"
      already_seen=0
      if [ "${#seen_children[@]}" -gt 0 ]; then
        for seen_child in "${seen_children[@]}"; do
          if [ "$seen_child" = "$real_child" ]; then
            already_seen=1
            break
          fi
        done
      fi

      [ "$already_seen" -eq 1 ] && continue
      seen_children+=("$real_child")

      name="$(basename "$child")"
      case "$agent:$name" in
        project-*:ai-config-bootstrap) continue ;;
      esac

      is_ignored_live_skill_name "$name" && continue
      repo_skill_exists "$name" && continue
      [ -f "$child/SKILL.md" ] || continue

      warn "unharvested local skill in $agent: $child"
    done < <(find "$root" -mindepth 1 -maxdepth 1 \( -type d -o -type l \) -print 2>/dev/null)
  done < <(
    skill_root_specs
    project_skill_root_specs
  )
}

check_cmux_reference_freshness() {
  local source_file="$AI_CONFIG_ROOT/skills/cmux-router/references/upstream/SOURCE.md"
  local source_url
  local imported
  local repo_url
  local branch_path
  local branch
  local remote

  [ -f "$source_file" ] || return 0

  if [ "$quick" -eq 1 ]; then
    return 0
  fi

  source_url="$(sed -n 's/^Source: //p' "$source_file" | head -n 1)"
  imported="$(sed -n 's/^Imported from commit: //p' "$source_file" | head -n 1)"

  if [ -z "$source_url" ] || [ -z "$imported" ]; then
    warn "cmux reference freshness marker is incomplete: $source_file"
    return 0
  fi

  case "$source_url" in
    https://github.com/*/tree/*)
      repo_url="${source_url%%/tree/*}"
      branch_path="${source_url#*/tree/}"
      branch="${branch_path%%/*}"
      ;;
    *)
      warn "cmux reference source URL is not understood: $source_url"
      return 0
      ;;
  esac

  remote="$(
    GIT_TERMINAL_PROMPT=0 git ls-remote "$repo_url" "refs/heads/$branch" 2>/dev/null |
      awk 'NR == 1 { print $1 }'
  )"

  if [ -z "$remote" ]; then
    log_info "could not check cmux reference freshness for $repo_url $branch"
    return 0
  fi

  if [ "$imported" != "$remote" ]; then
    warn "cmux reference skills out of date: imported $imported, upstream $branch is $remote ($source_url)"
  else
    log_info "cmux reference skills up to date: $imported"
  fi
}

check_secret_scan() {
  local paths=()
  local findings

  while IFS= read -r path; do
    paths+=("$path")
  done < <(existing_scan_paths "${PORTABLE_SCAN_PATHS[@]}")

  findings="$(scan_secret_regex_paths "${paths[@]}")"
  if [ -n "$findings" ]; then
    err "possible secret found:"
    printf '%s\n' "$findings" >&2
  fi
}

print_statusline_snippet() {
  cat >&2 <<'SNIPPET'
  merge this into ~/.claude/settings.json:
    "statusLine": {
      "command": "$HOME/.claude/statusline.sh",
      "type": "command"
    }
SNIPPET
}

check_claude_statusline_settings() {
  local settings="$HOME/.claude/settings.json"
  local expected="$HOME/.claude/statusline.sh"
  local command

  [ -f "$settings" ] || {
    warn "claude settings missing: $settings"
    print_statusline_snippet
    return
  }

  if ! command -v jq >/dev/null 2>&1; then
    warn "jq not installed; skipping statusLine check in $settings"
    return
  fi

  command="$(jq -r '.statusLine.command // ""' "$settings" 2>/dev/null)"

  case "$command" in
    "")
      warn "statusLine.command not set in $settings"
      print_statusline_snippet
      ;;
    "$expected"|'$HOME/.claude/statusline.sh'|"~/.claude/statusline.sh")
      [ "$quick" -eq 1 ] || log_info "statusLine ok: $command"
      ;;
    *)
      warn "statusLine.command in $settings points elsewhere: $command (expected $expected)"
      print_statusline_snippet
      ;;
  esac
}

check_portability_scan() {
  local paths=()
  local findings

  while IFS= read -r path; do
    paths+=("$path")
  done < <(existing_scan_paths "${PORTABLE_SCAN_PATHS[@]}")

  findings="$(scan_portability_paths "${paths[@]}")"
  if [ -n "$findings" ]; then
    err "absolute home path found in portable file:"
    printf '%s\n' "$findings" >&2
  fi
}

check_git
check_portable_links
check_skill_links
check_unharvested_live_skills
check_cmux_reference_freshness
check_claude_statusline_settings
check_secret_scan
check_portability_scan

if [ "$errors" -gt 0 ]; then
  log_error "ai-doctor found $errors error(s) and $warnings warning(s)"
  exit 1
fi

if [ "$warnings" -gt 0 ]; then
  log_warn "ai-doctor found $warnings warning(s)"
  [ "$strict" -eq 1 ] && exit 1
  exit 0
fi

log_info "ai-doctor ok"
