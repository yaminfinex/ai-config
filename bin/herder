#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)/lib/common.sh"
export AI_CONFIG_ROOT

src_dir="$AI_CONFIG_ROOT/tools/herder"

hash_cmd=()
if command -v sha256sum >/dev/null 2>&1; then
  hash_cmd=(sha256sum)
elif [ -x /sbin/sha256sum ]; then
  hash_cmd=(/sbin/sha256sum)
elif command -v shasum >/dev/null 2>&1; then
  hash_cmd=(shasum -a 256)
else
  log_error "herder: no sha256 tool found"
  exit 1
fi

cache_candidates=()
if [ -n "${XDG_CACHE_HOME:-}" ]; then
  cache_candidates+=("$XDG_CACHE_HOME/herder")
fi
if [ -n "${HOME:-}" ]; then
  cache_candidates+=("$HOME/.cache/herder")
fi
cache_candidates+=("${TMPDIR:-/tmp}/herder-cache-${UID:-$(id -u 2>/dev/null || printf unknown)}/herder")

cache_dir=""
for candidate in "${cache_candidates[@]}"; do
  if mkdir -p "$candidate" 2>/dev/null && [ -w "$candidate" ]; then
    cache_dir="$candidate"
    break
  fi
done

if [ -z "$cache_dir" ]; then
  log_error "herder: no writable cache directory found"
  exit 1
fi

if [ -z "${GOCACHE:-}" ] || ! mkdir -p "$GOCACHE" 2>/dev/null || [ ! -w "$GOCACHE" ]; then
  export GOCACHE="$cache_dir/go-build"
  mkdir -p "$GOCACHE"
fi

# Key the cached binary on a hash of the module sources so a source change
# triggers a rebuild and an unchanged tree reuses the cache.
src_hash="$(
  cd "$src_dir" &&
    find go.mod cmd internal -type f \( -name '*.go' -o -name 'go.mod' -o -name 'go.sum' \) -print0 |
    sort -z |
    xargs -0 "${hash_cmd[@]}" |
    "${hash_cmd[@]}" |
    cut -c1-16
)"

herder_bin="$cache_dir/herder-$src_hash"

if [ ! -x "$herder_bin" ]; then
  if command -v go >/dev/null 2>&1; then
    go_cmd=(env -u GOROOT go)
  elif command -v mise >/dev/null 2>&1; then
    go_cmd=(mise x go -- go)
  else
    log_error "herder: no go toolchain found — install one with: mise use -g go"
    exit 1
  fi

  mkdir -p "$cache_dir"
  rm -f "$cache_dir"/herder-*
  (cd "$src_dir" && "${go_cmd[@]}" build -o "$herder_bin.tmp.$$" ./cmd/herder)
  mv "$herder_bin.tmp.$$" "$herder_bin"
fi

exec "$herder_bin" "$@"
