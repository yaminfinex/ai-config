#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  cmux-agent-send --to surface:N [--workspace workspace:N] (--file PATH | --text TEXT | --stdin) [--submit]

Sends a payload to a cmux surface with cmux send. With --submit, also sends Enter.
Omit --submit for noninterrupting delivery.
USAGE
}

workspace=""
surface=""
file=""
text=""
use_stdin=false
submit=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --workspace)
      workspace="${2:-}"
      shift 2
      ;;
    --to|--surface)
      surface="${2:-}"
      shift 2
      ;;
    --file)
      file="${2:-}"
      shift 2
      ;;
    --text)
      text="${2:-}"
      shift 2
      ;;
    --stdin)
      use_stdin=true
      shift
      ;;
    --submit)
      submit=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ -z "$surface" ]]; then
  echo "Missing --to surface:N" >&2
  usage >&2
  exit 2
fi

sources=0
[[ -n "$file" ]] && sources=$((sources + 1))
[[ -n "$text" ]] && sources=$((sources + 1))
[[ "$use_stdin" == true ]] && sources=$((sources + 1))

if [[ "$sources" -ne 1 ]]; then
  echo "Provide exactly one payload source: --file, --text, or --stdin" >&2
  usage >&2
  exit 2
fi

if [[ -n "$file" ]]; then
  payload="$(<"$file")"
elif [[ "$use_stdin" == true ]]; then
  payload="$(cat)"
else
  payload="$text"
fi

cmd=(cmux send --surface "$surface")
key_cmd=(cmux send-key --surface "$surface")

if [[ -n "$workspace" ]]; then
  cmd+=(--workspace "$workspace")
  key_cmd+=(--workspace "$workspace")
fi

"${cmd[@]}" "$payload"

if [[ "$submit" == true ]]; then
  "${key_cmd[@]}" Enter
fi
