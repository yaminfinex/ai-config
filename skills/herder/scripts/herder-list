#!/usr/bin/env bash
# herder-list — show spawned agents, optionally reconciled with live herdr state.
#
# Usage:
#   herder-list                       # table of active records, reconciled with live agents
#   herder-list --all                 # include records with status != active
#   herder-list --json                # raw JSONL of reconciled records to stdout
#   herder-list --raw                 # raw registry JSONL without reconciliation
#   herder-list --guid GUID           # single record (full JSON), exit 1 if missing
#   herder-list --teams               # enumerate team buses under $HERDER_TEAMS_ROOT

set -euo pipefail

die() { printf 'herder-list: %s\n' "$*" >&2; exit 1; }
command -v herdr >/dev/null 2>&1 || die "herdr not on PATH"
command -v jq >/dev/null 2>&1 || die "jq not on PATH"

STATE_DIR="${HERDER_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/herder}"
REGISTRY="$STATE_DIR/registry.jsonl"
TEAMS_ROOT="${HERDER_TEAMS_ROOT:-$HOME/.hcom/teams}"

MODE="table"
INCLUDE_ALL=0
TARGET_GUID=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --all) INCLUDE_ALL=1; shift;;
    --json) MODE="json"; shift;;
    --raw) MODE="raw"; shift;;
    --guid) MODE="one"; TARGET_GUID="$2"; shift 2;;
    --teams) MODE="teams"; shift;;
    -h|--help) sed -n '1,13p' "$0"; exit 0;;
    *) die "unknown arg: $1";;
  esac
done

# --teams: enumerate team buses (D7). Each immediate subdir of $HERDER_TEAMS_ROOT is
# a team's HCOM_DIR. The global bus (~/.hcom, no team) is always listed first. This
# reads the filesystem, not the registry, so it surfaces teams even with no live agent.
if [[ "$MODE" == "teams" ]]; then
  printf '%-20s %s\n' "TEAM" "HCOM_DIR"
  printf '%-20s %s\n' "global" "$HOME/.hcom"
  if [[ -d "$TEAMS_ROOT" ]]; then
    for d in "$TEAMS_ROOT"/*/; do
      [[ -d "$d" ]] || continue
      name="$(basename "$d")"
      printf '%-20s %s\n' "$name" "${d%/}"
    done
  fi
  exit 0
fi

[[ -f "$REGISTRY" ]] || { printf 'no registry at %s\n' "$REGISTRY" >&2; exit 0; }

if [[ "$MODE" == "raw" ]]; then
  cat "$REGISTRY"
  exit 0
fi

# Reconcile by terminal_id, NOT the stored pane_id. herdr compacts/reassigns
# pane_ids as panes close, so a record's spawn-time pane_id can now point at a
# different agent — keying the live lookup by pane_id would report that other
# agent's status. terminal_id is durable, so it both reports the right status and
# surfaces the agent's CURRENT pane (live_pane) vs. where it spawned (pane_id).
LIVE_JSON="$(herdr agent list 2>/dev/null || printf '{"result":{"agents":[]}}')"
LIVE_BY_TERM="$(printf '%s' "$LIVE_JSON" | jq -c '[.result.agents[]? | select(.terminal_id != null) | {(.terminal_id): .}] | add // {}')"

reconcile() {
  jq -c --argjson live "$LIVE_BY_TERM" \
    '($live[.terminal_id] // null) as $l
     | . + {live: $l,
            live_pane: ($l.pane_id // null),
            live_status: (($l.agent_status) // "gone")}'
}

if [[ "$MODE" == "one" ]]; then
  [[ -n "$TARGET_GUID" ]] || die "--guid requires a value"
  REC="$(grep -F "\"$TARGET_GUID\"" "$REGISTRY" | tail -n1 || true)"
  [[ -n "$REC" ]] || { printf 'no record for guid %s\n' "$TARGET_GUID" >&2; exit 1; }
  printf '%s' "$REC" | reconcile | jq .
  exit 0
fi

# Collapse to latest record per guid so closed/updated entries override earlier ones.
if [[ "$INCLUDE_ALL" -eq 1 ]]; then
  COLLAPSED="$(jq -sc 'group_by(.guid) | map(.[-1]) | .[]' "$REGISTRY")"
else
  COLLAPSED="$(jq -sc 'group_by(.guid) | map(.[-1]) | map(select(.status=="active")) | .[]' "$REGISTRY")"
fi

if [[ "$MODE" == "json" ]]; then
  printf '%s\n' "$COLLAPSED" | while IFS= read -r rec; do
    [[ -n "$rec" ]] || continue
    printf '%s' "$rec" | reconcile
  done
  exit 0
fi

# Table mode. TEAM = the peer's team bus (empty → global); BUS = its hcom bus name
# (@name) or '-' for non-bus (herdr keystroke) peers.
printf '%-10s %-20s %-7s %-18s %-9s %-12s %-16s %s\n' \
  "GUID" "LABEL" "AGENT" "PANE" "LIVE" "TEAM" "BUS" "ROLE"
printf '%s\n' "$COLLAPSED" | while IFS= read -r rec; do
  [[ -n "$rec" ]] || continue
  reconciled="$(printf '%s' "$rec" | reconcile)"
  printf '%-10s %-20s %-7s %-18s %-9s %-12s %-16s %s\n' \
    "$(printf '%s' "$reconciled" | jq -r .short_guid)" \
    "$(printf '%s' "$reconciled" | jq -r .label)" \
    "$(printf '%s' "$reconciled" | jq -r .agent)" \
    "$(printf '%s' "$reconciled" | jq -r '.live_pane // .pane_id')" \
    "$(printf '%s' "$reconciled" | jq -r .live_status)" \
    "$(printf '%s' "$reconciled" | jq -r '(.team // "") | if . == "" then "global" else . end')" \
    "$(printf '%s' "$reconciled" | jq -r '(.hcom_name // "") | if . == "" or . == null then "-" else "@" + . end')" \
    "$(printf '%s' "$reconciled" | jq -r .role)"
done
