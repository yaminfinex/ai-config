#!/usr/bin/env bash
# herder-cull — close a spawned agent's pane and mark its registry record closed.
#
# Usage:
#   herder-cull --guid GUID                 # match by short or full guid
#   herder-cull --label LABEL                # match by label
#   herder-cull --pane PANE_ID               # match by pane id
#   herder-cull --gone                       # close registry entries whose pane is no longer live
#   add --dry-run to print what would happen without acting.
#   add --force to skip terminal_id verification (use only when you've confirmed
#       the agent is dead and you need to mark the registry row closed).
#
# Updates the registry by appending a new closed record (registry is append-only JSONL).
#
# Safety: before calling `herdr pane close`, looks up the pane via `herdr pane get`
# and confirms `terminal_id` matches the spawn-time terminal_id from the registry
# row. Mismatch means herdr id compaction has reassigned the pane_id to a
# different agent — refuse + log rather than close someone else's work.

set -euo pipefail

die() { printf 'herder-cull: %s\n' "$*" >&2; exit 1; }
[[ "${HERDR_ENV:-}" = "1" ]] || die "not running inside a herdr pane (HERDR_ENV != 1)"
command -v herdr >/dev/null 2>&1 || die "herdr not on PATH"
command -v jq >/dev/null 2>&1 || die "jq not on PATH"

STATE_DIR="${HERDER_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/herder}"
REGISTRY="$STATE_DIR/registry.jsonl"
[[ -f "$REGISTRY" ]] || die "no registry at $REGISTRY"

SELECTOR=""
SELECTOR_VAL=""
GONE_ONLY=0
DRY=0
FORCE=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --guid) SELECTOR="guid"; SELECTOR_VAL="$2"; shift 2;;
    --label) SELECTOR="label"; SELECTOR_VAL="$2"; shift 2;;
    --pane) SELECTOR="pane"; SELECTOR_VAL="$2"; shift 2;;
    --gone) GONE_ONLY=1; shift;;
    --dry-run) DRY=1; shift;;
    --force) FORCE=1; shift;;
    -h|--help) sed -n '1,18p' "$0"; exit 0;;
    *) die "unknown arg: $1";;
  esac
done

# Build the latest-by-guid view: last record wins, keep only currently-active rows.
LATEST="$(jq -sc 'group_by(.guid) | map(.[-1]) | .[] | select(.status=="active")' "$REGISTRY")"

# Snapshot live state once. Index by terminal_id (durable across pane_id compaction)
# so we can decide what's actually gone vs. what's just been renumbered.
LIVE_JSON="$(herdr agent list 2>/dev/null || printf '{"result":{"agents":[]}}')"
LIVE_TERMS="$(printf '%s' "$LIVE_JSON" | jq -c '[.result.agents[]?.terminal_id]')"

# Where does a terminal_id live *right now*? pane_ids compact when sibling panes
# close, so an agent's recorded pane_id can go stale while the agent is still
# alive at a renumbered pane. Resolving by terminal_id finds its current home.
live_pane_for_term() {
  local term="$1"
  [[ -n "$term" ]] || return 0
  printf '%s' "$LIVE_JSON" | jq -r --arg t "$term" \
    '.result.agents[]? | select(.terminal_id==$t) | .pane_id' 2>/dev/null | head -n1
}

select_targets() {
  if [[ "$GONE_ONLY" -eq 1 ]]; then
    # Truly-gone = registry terminal_id is not present in the live agent list.
    # This is durable under pane_id compaction; the old `pane_id IN live` check
    # was not.
    printf '%s\n' "$LATEST" | jq -c --argjson live "$LIVE_TERMS" \
      'select((.terminal_id|IN($live[]))|not)'
    return
  fi
  case "$SELECTOR" in
    guid)  printf '%s\n' "$LATEST" | jq -c --arg v "$SELECTOR_VAL" 'select(.guid==$v or .short_guid==$v)';;
    label) printf '%s\n' "$LATEST" | jq -c --arg v "$SELECTOR_VAL" 'select(.label==$v)';;
    pane)  printf '%s\n' "$LATEST" | jq -c --arg v "$SELECTOR_VAL" 'select(.pane_id==$v)';;
    "")    die "selector required (--guid, --label, --pane, or --gone)";;
  esac
}

TARGETS="$(select_targets)"
[[ -n "$TARGETS" ]] || { printf 'no matching active records\n' >&2; exit 1; }

NOW_ISO="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
CULLER="${HERDR_PANE_ID:-unknown}"

append_closed() {
  # $1 = registry record, $2 = close_result enum, $3 = reason text
  printf '%s' "$1" | jq -c \
    --arg now "$NOW_ISO" --arg by "$CULLER" \
    --arg result "$2" --arg reason "$3" \
    '. + {status:"closed", closed_at:$now, closed_by_pane:$by,
          close_result:$result, close_reason:$reason}' \
    >>"$REGISTRY"
}

verify_pane_identity() {
  # $1 = stored pane_id, $2 = stored terminal_id
  # Returns 0 if pane still resolves to the same terminal_id; 1 if gone; 2 if reassigned.
  local pane="$1" want_term="$2" got_json got_term
  got_json="$(herdr pane get "$pane" 2>&1 || true)"
  got_term="$(printf '%s' "$got_json" | jq -r '.result.pane.terminal_id // empty' 2>/dev/null || true)"
  if [[ -z "$got_term" ]]; then
    return 1  # gone
  fi
  if [[ "$got_term" != "$want_term" ]]; then
    return 2  # reassigned
  fi
  return 0
}

printf '%s\n' "$TARGETS" | while IFS= read -r rec; do
  [[ -n "$rec" ]] || continue
  GUID="$(printf '%s' "$rec" | jq -r .guid)"
  LABEL="$(printf '%s' "$rec" | jq -r .label)"
  PANE="$(printf '%s' "$rec" | jq -r .pane_id)"
  TERM="$(printf '%s' "$rec" | jq -r '.terminal_id // empty')"

  if [[ "$DRY" -eq 1 ]]; then
    printf 'would cull %s (%s) pane=%s\n' "$LABEL" "$GUID" "$PANE"
    continue
  fi

  # In --gone mode, the record is already known not-live; don't bother calling
  # `pane close` (would noisily error). Just record the closure.
  if [[ "$GONE_ONLY" -eq 1 ]]; then
    append_closed "$rec" "already_gone" "terminal_id not in live agent list"
    printf 'recorded closed %s (%s) pane=%s → already_gone\n' "$LABEL" "$GUID" "$PANE"
    continue
  fi

  # For explicit-target culls: verify the pane still maps to the same agent
  # before closing. Pane ids compact across session events, so when the recorded
  # pane id is stale (gone, or now belongs to a different terminal) we re-resolve
  # the agent by its durable terminal_id and retarget the close to wherever it
  # lives now. We only declare it gone when the terminal_id isn't live anywhere —
  # which fixes the bug where culling a sibling renumbered an agent's pane and
  # left the still-running agent falsely marked closed.
  if [[ "$FORCE" -ne 1 && -n "$TERM" ]]; then
    set +e
    verify_pane_identity "$PANE" "$TERM"
    VRC=$?
    set -e
    case "$VRC" in
      0) ;;  # recorded pane still holds this terminal — close as-is
      1|2)
        LIVE_PANE="$(live_pane_for_term "$TERM")"
        if [[ -n "$LIVE_PANE" ]]; then
          printf 'pane id drifted for %s (%s): registry=%s, terminal %s now live at %s — retargeting\n' \
            "$LABEL" "$GUID" "$PANE" "$TERM" "$LIVE_PANE" >&2
          PANE="$LIVE_PANE"
        else
          if [[ "$VRC" -eq 1 ]]; then
            printf 'pane %s gone and terminal %s not live anywhere; recording closed without API call\n' \
              "$PANE" "$TERM" >&2
          else
            printf 'pane %s reassigned to another terminal and %s not live anywhere; recording closed\n' \
              "$PANE" "$TERM" >&2
          fi
          append_closed "$rec" "already_gone" "terminal_id not in live agent list"
          continue
        fi
        ;;
    esac
  fi

  RESULT="$(herdr pane close "$PANE" 2>&1 || true)"
  CLOSED_OK="$(printf '%s' "$RESULT" | jq -r '.result.type // "error"' 2>/dev/null || echo error)"

  if [[ "$CLOSED_OK" == "error" ]]; then
    # Close errored — still record the row as closed so the registry doesn't stay
    # inconsistent. Capture a short reason from the error payload.
    REASON="$(printf '%s' "$RESULT" | jq -r '.error.code // .error.message // "unknown_error"' 2>/dev/null || echo unknown_error)"
    append_closed "$rec" "error" "$REASON"
    printf 'cull errored %s (%s) pane=%s → %s (still marked closed in registry)\n' \
      "$LABEL" "$GUID" "$PANE" "$REASON"
  else
    append_closed "$rec" "$CLOSED_OK" ""
    printf 'culled %s (%s) pane=%s → %s\n' "$LABEL" "$GUID" "$PANE" "$CLOSED_OK"
  fi
done
