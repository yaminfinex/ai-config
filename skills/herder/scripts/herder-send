#!/usr/bin/env bash
# herder-send — send a message to an already-spawned peer agent, safely.
#
# Usage:
#   herder-send <target> <message> [opts]
#
# <target>: short-guid, full guid, label, terminal_id (term_*), or pane_id. A
# guid/label is resolved to the agent's CURRENT pane via its durable terminal_id
# (registry pane_ids go stale as herdr compacts ids — see "resolve" below); a bare
# term_* is resolved the same drift-proof way without needing a registry record
# (this is what `herder-spawn --notify` injects for the orchestrator ring). A raw
# pane_id is used verbatim.
#
# Options:
#   --dry-run            resolve the target and report where it would send, then
#                        exit WITHOUT pasting anything (debug a mis-send safely)
#   --no-enter           place text into the prompt but don't submit
#   --no-verify          skip post-send delivery verification
#   --force              skip pre-flight state check (still verifies delivery)
#   --timeout MS         max time to wait for the prompt buffer to clear (default 3000)
#   --json               emit a JSON record on stdout describing the send
#
# The send is dispatched through the delivery-driver interface, which selects
# a transport (herdr keystroke, hcom hooks, etc.) automatically.
#
# Exit codes:
#   0  — sent + verified, OR queued (target was busy; message accepted to run next)
#   1  — send or verification failed
#   2  — refused: target gone (terminal not live) or in interrupted/modal state
#   64 — usage error
#

set -euo pipefail

die() { printf 'herder-send: %s\n' "$*" >&2; exit 64; }
[[ "${HERDR_ENV:-}" = "1" ]] || die "not running inside a herdr pane (HERDR_ENV != 1)"
command -v herdr >/dev/null 2>&1 || die "herdr not on PATH"
command -v jq >/dev/null 2>&1 || die "jq not on PATH"

TARGET=""
MESSAGE=""
NO_ENTER=0
NO_VERIFY=0
FORCE=0
TIMEOUT_MS=3000
JSON_OUT=0
DRY_RUN=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)   DRY_RUN=1; shift;;
    --no-enter)  NO_ENTER=1; shift;;
    --no-verify) NO_VERIFY=1; shift;;
    --force)     FORCE=1; shift;;
    --timeout)   TIMEOUT_MS="$2"; shift 2;;
    --json)      JSON_OUT=1; shift;;
    -h|--help)   sed -n '1,40p' "$0"; exit 0;;
    --*)         die "unknown flag: $1";;
    *)
      if   [[ -z "$TARGET"  ]]; then TARGET="$1"
      elif [[ -z "$MESSAGE" ]]; then MESSAGE="$1"
      else die "extra positional arg: $1"
      fi
      shift
      ;;
  esac
done

[[ -n "$TARGET"  ]] || die "target required (guid, label, or pane id)"
[[ -n "$MESSAGE" || "$DRY_RUN" -eq 1 ]] || die "message required"

# ---- dispatch through delivery-driver interface ----

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/delivery-driver.sh"

if [[ "$DRY_RUN" -eq 1 ]]; then
  # Resolve via the herdr driver for --dry-run
  # Call _herdr_resolve_internal to get "pane_id|resolved_via|drifted|drift_note" format
  resolve_output="$(_herdr_resolve_internal "$TARGET" 2>/dev/null)" || {
    rc=$?
    [[ $rc -eq 2 ]] && exit 2 || exit 1
  }

  # Parse: pane_id|resolved_via|drifted|drift_note
  # Use IFS to split on |, but drift_note may contain |, so split manually
  pane_id="$(printf '%s' "$resolve_output" | cut -d'|' -f1)"
  resolved_via="$(printf '%s' "$resolve_output" | cut -d'|' -f2)"
  drifted="$(printf '%s' "$resolve_output" | cut -d'|' -f3)"
  drift_note="$(printf '%s' "$resolve_output" | cut -d'|' -f4-)"

  # Emit drift warning if applicable
  [[ "$drift_note" != "" ]] && printf 'herder-send: %s\n' "$drift_note" >&2

  printf 'herder-send --dry-run: %s -> pane %s (via %s)%s\n' \
    "$TARGET" "$pane_id" "$resolved_via" \
    "$([[ "$drifted" == "true" ]] && printf ' [DRIFTED]')" >&2

  if [[ "$JSON_OUT" -eq 1 ]]; then
    jq -nc --arg pane "$pane_id" --arg target "$TARGET" --arg via "$resolved_via" \
      --argjson drifted "$([[ "$drifted" == "true" ]] && echo true || echo false)" \
      '{pane_id:$pane, target:$target, resolved_via:$via, drifted:$drifted, dry_run:true}'
  fi
  exit 0
fi

# Dispatch the send through the driver, forwarding the send options so the driver
# honours --no-enter (place, don't submit), --no-verify (skip poll), --force (skip
# pre-flight), --timeout (wait budget), and --json (emit the record on stdout).
rc=0
driver_dispatch send "$TARGET" "$MESSAGE" \
  --no-enter "$NO_ENTER" \
  --no-verify "$NO_VERIFY" \
  --force "$FORCE" \
  --timeout "$TIMEOUT_MS" \
  --json "$JSON_OUT" || rc=$?
exit "$rc"
