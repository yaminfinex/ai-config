#!/usr/bin/env bash
# herder-spawn — spawn a named, GUID-tagged agent in a herdr pane and register it.
#
# Usage:
#   herder-spawn --role <role> --agent <claude|codex|bash|...> [--prompt TEXT | --prompt-file FILE]
#                [--split right|down] [--workspace ID | --from-pane PANE_ID] [--tab ID | --new-tab] [--cwd PATH]
#                [--no-focus] [--safe] [--label-prefix STR] [--extra-arg ARG]... [--json]
#
# Tab placement:
#   * --tab <id>  places the agent in an existing tab (as a split alongside whatever is there).
#   * --new-tab   gives the agent its own fresh tab with NO spare shell. `herdr tab create` always
#                 seeds a tab with a default shell (root) pane, and `herdr agent start` always opens
#                 a NEW pane (even without --split), so a naive "tab create + agent start --tab"
#                 leaves the root shell behind. --new-tab creates the tab, spawns the agent into it,
#                 then closes the root shell (verifying its terminal_id first so it never closes the
#                 agent) and re-resolves the agent's pane_id by terminal_id after the close compacts
#                 ids. The tab is labelled with the agent's label. --new-tab and --tab are exclusive.
#
# Behavior:
#   1. Generates a short GUID and a label "<role>-<shortguid>".
#   2. PERMISSIONS: by default spawns agents in autonomous ("YOLO") mode so they don't stall on
#      approval prompts the herder can't see — claude gets --dangerously-skip-permissions, codex gets
#      --dangerously-bypass-approvals-and-sandbox. This is injected because `exec claude` bypasses the
#      user's shell alias (which is where skip-permissions usually lives), so spawned agents would
#      otherwise come up in ask-mode. Pass --safe to opt out, or pass your own permission flag via
#      --extra-arg (any recognised one suppresses the default).
#   3. Calls `herdr agent start <label> ...`, launching the agent inside a login+interactive shell —
#      `$SHELL -lic 'export HERDER_GUID=... HERDER_ROLE=... HERDER_LABEL=...; exec <agent> [extra-args]'` —
#      so PATH / mise activation / auth env are sourced like a normal pane. Opt out with --no-login-shell.
#   4. Appends a JSONL record to $HERDER_STATE_DIR/registry.jsonl.
#   5. If --prompt/--prompt-file is given, waits for the agent to become truly ready (sigil + idle +
#      settle) then delegates delivery to `herder-send` (verified, with double-Enter recovery).
#   6. Prints a human summary to stderr and a JSON record to stdout when --json is set.
#
# Notes:
#   * The agent binary must accept being invoked plainly (e.g. `codex`, `claude`). For wrappers, use --extra-arg.
#   * Initial-prompt delivery is verified by `herder-send`; if it can't confirm submission it reports
#     prompt: NOT confirmed rather than silently claiming success.

set -euo pipefail

die() { printf 'herder-spawn: %s\n' "$*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

[[ "${HERDR_ENV:-}" = "1" ]] || die "not running inside a herdr pane (HERDR_ENV != 1)"
have herdr || die "herdr not on PATH"
have jq || die "jq not on PATH"
have uuidgen || die "uuidgen not on PATH"

ROLE=""
AGENT=""
PROMPT=""
PROMPT_FILE=""
SPLIT="right"
WORKSPACE=""
FROM_PANE=""
TAB=""
NEW_TAB=0
CWD=""
FOCUS_FLAG="--no-focus"
LABEL_PREFIX=""
EXTRA_ARGS=()
JSON_OUT=0
WAIT_TIMEOUT_MS="${HERDER_SPAWN_WAIT_MS:-15000}"
READY_MATCH=""
NO_READY_WAIT=0
LOGIN_SHELL=1
LOGIN_SHELL_BIN="${HERDER_SPAWN_SHELL:-${SHELL:-/bin/bash}}"
SAFE=0
SETTLE_MS="${HERDER_SPAWN_SETTLE_MS:-1500}"

# Sibling scripts live next to this one; resolve their dir so we can delegate
# initial-prompt delivery to herder-send (verified send) regardless of $PATH.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Per-agent default permission flag. We inject this so spawned agents come up in
# autonomous mode (the herder can't see or answer an approval modal in a child
# pane). `exec <agent>` bypasses the user's shell alias, so without this claude
# spawns in ask-mode even when the user's interactive `claude` is aliased to
# --dangerously-skip-permissions.
default_perm_flag() {
  case "$1" in
    claude) printf '%s' '--dangerously-skip-permissions';;
    codex)  printf '%s' '--dangerously-bypass-approvals-and-sandbox';;
    *)      printf '';;
  esac
}

# Does the caller's --extra-arg list already carry a permission-shaping flag? If
# so, respect it and don't inject our default.
has_explicit_perm_flag() {
  local a
  for a in ${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"}; do
    case "$a" in
      # claude
      --dangerously-skip-permissions|--permission-mode|--permission-prompt-tool) return 0;;
      # codex
      --dangerously-bypass-approvals-and-sandbox|--full-auto|-a|--ask-for-approval|-s|--sandbox) return 0;;
    esac
  done
  return 1
}


while [[ $# -gt 0 ]]; do
  case "$1" in
    --role) ROLE="$2"; shift 2;;
    --agent) AGENT="$2"; shift 2;;
    --prompt) PROMPT="$2"; shift 2;;
    --prompt-file) PROMPT_FILE="$2"; shift 2;;
    --split) SPLIT="$2"; shift 2;;
    --workspace) WORKSPACE="$2"; shift 2;;
    --from-pane) FROM_PANE="$2"; shift 2;;
    --tab) TAB="$2"; shift 2;;
    --new-tab) NEW_TAB=1; shift;;
    --cwd) CWD="$2"; shift 2;;
    --focus) FOCUS_FLAG="--focus"; shift;;
    --no-focus) FOCUS_FLAG="--no-focus"; shift;;
    --label-prefix) LABEL_PREFIX="$2"; shift 2;;
    --extra-arg) EXTRA_ARGS+=("$2"); shift 2;;
    --json) JSON_OUT=1; shift;;
    --wait-timeout-ms) WAIT_TIMEOUT_MS="$2"; shift 2;;
    --ready-match) READY_MATCH="$2"; shift 2;;
    --no-ready-wait) NO_READY_WAIT=1; shift;;
    --no-login-shell) LOGIN_SHELL=0; shift;;
    --login-shell) LOGIN_SHELL_BIN="$2"; shift 2;;
    --safe) SAFE=1; shift;;
    -h|--help) sed -n '2,38p' "$0"; exit 0;;
    *) die "unknown arg: $1";;
  esac
done

[[ -n "$ROLE" ]] || die "--role required"
[[ -n "$AGENT" ]] || die "--agent required"
[[ -z "$PROMPT" || -z "$PROMPT_FILE" ]] || die "use --prompt or --prompt-file, not both"
[[ -z "$WORKSPACE" || -z "$FROM_PANE" ]] || die "use --workspace or --from-pane, not both"
[[ "$NEW_TAB" -eq 0 || -z "$TAB" ]] || die "use --new-tab or --tab, not both"

# Resolve --from-pane → its workspace_id, so the new pane lands in the same
# workspace as the named parent (not wherever focus happens to be).
if [[ -n "$FROM_PANE" ]]; then
  FROM_PANE_JSON="$(herdr pane get "$FROM_PANE" 2>&1 || true)"
  WORKSPACE="$(printf '%s' "$FROM_PANE_JSON" | jq -r '.result.pane.workspace_id // empty' 2>/dev/null || true)"
  [[ -n "$WORKSPACE" ]] || die "--from-pane $FROM_PANE: pane not found (herdr pane get returned: $FROM_PANE_JSON)"
fi

# Validate --workspace against the live workspace list before calling agent start.
# Herdr workspace ids are session-live; after a herdr restart they all change, and
# a stale id surfaces as a cryptic `agent_placement_not_found` JSON error. Fail
# early with a clear message instead.
if [[ -n "$WORKSPACE" ]]; then
  WS_LIST_JSON="$(herdr workspace list 2>&1 || true)"
  WS_HIT="$(printf '%s' "$WS_LIST_JSON" | jq -r --arg ws "$WORKSPACE" \
    '.result.workspaces[]? | select(.workspace_id==$ws) | .workspace_id' 2>/dev/null || true)"
  if [[ -z "$WS_HIT" ]]; then
    {
      printf 'herder-spawn: --workspace %s not found in live workspace list.\n' "$WORKSPACE"
      printf 'Herdr workspace ids are session-live; they change after a herdr restart.\n'
      printf 'Live workspaces:\n'
      printf '%s' "$WS_LIST_JSON" | jq -r '.result.workspaces[]? | "  \(.workspace_id)  \(.label // "(no label)")  \(.worktree.checkout_path // .worktree.repo_root // "")"' 2>/dev/null || true
    } >&2
    exit 2
  fi
fi

if [[ -n "$PROMPT_FILE" ]]; then
  [[ -r "$PROMPT_FILE" ]] || die "prompt file not readable: $PROMPT_FILE"
  PROMPT="$(cat "$PROMPT_FILE")"
fi

# Inject the autonomous-mode permission flag unless --safe or the caller already
# passed one. Prepend so an explicit later --extra-arg still wins if it conflicts.
PERM_INJECTED=""
if [[ "$SAFE" -eq 0 ]]; then
  PERM_FLAG="$(default_perm_flag "$AGENT")"
  if [[ -n "$PERM_FLAG" ]] && ! has_explicit_perm_flag; then
    EXTRA_ARGS=("$PERM_FLAG" ${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"})
    PERM_INJECTED="$PERM_FLAG"
  fi
fi

STATE_DIR="${HERDER_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/herder}"
mkdir -p "$STATE_DIR"
REGISTRY="$STATE_DIR/registry.jsonl"

# Generate IDs. Full UUID is the canonical handle; short form is for human labels.
GUID="$(uuidgen | tr 'A-Z' 'a-z')"
SHORT="${GUID%%-*}"
LABEL="${LABEL_PREFIX}${ROLE}-${SHORT}"

# --new-tab: create a dedicated tab for this agent with no spare shell. `tab create`
# seeds the tab with a root shell pane; we capture its pane_id + terminal_id so we
# can close it after the agent lands (see post-start cleanup below). Set TAB so the
# normal `agent start --tab` path places the agent in this tab.
ROOT_PANE_ID=""
ROOT_TERM=""
if [[ "$NEW_TAB" -eq 1 ]]; then
  tab_args=("tab" "create" "--no-focus" "--label" "$LABEL")
  [[ -n "$WORKSPACE" ]] && tab_args+=("--workspace" "$WORKSPACE")
  [[ -n "$CWD" ]]       && tab_args+=("--cwd" "$CWD")
  set +e
  TAB_CREATE_JSON="$(herdr "${tab_args[@]}" 2>&1)"
  TAB_CREATE_RC=$?
  set -e
  if [[ $TAB_CREATE_RC -ne 0 ]]; then
    printf 'herdr tab create failed:\n%s\n' "$TAB_CREATE_JSON" >&2
    exit "$TAB_CREATE_RC"
  fi
  TAB="$(printf '%s' "$TAB_CREATE_JSON" | jq -r '.result.tab.tab_id // empty')"
  ROOT_PANE_ID="$(printf '%s' "$TAB_CREATE_JSON" | jq -r '.result.root_pane.pane_id // empty')"
  ROOT_TERM="$(printf '%s' "$TAB_CREATE_JSON" | jq -r '.result.root_pane.terminal_id // empty')"
  [[ -n "$TAB" && -n "$ROOT_PANE_ID" ]] || { printf 'unexpected tab create payload: %s\n' "$TAB_CREATE_JSON" >&2; exit 1; }
fi

# Build herdr agent start arg list.
start_args=("agent" "start" "$LABEL" "$FOCUS_FLAG" "--split" "$SPLIT")
[[ -n "$WORKSPACE" ]] && start_args+=("--workspace" "$WORKSPACE")
[[ -n "$TAB" ]]       && start_args+=("--tab" "$TAB")
[[ -n "$CWD" ]]       && start_args+=("--cwd" "$CWD")

# argv: how we invoke the agent in the new pane.
#
# Default path: wrap in the user's login+interactive shell so PATH, mise activation, auth env,
# etc. are sourced from .zshrc/.bashrc/.zprofile the same way Cmd+D-style panes are. The herdr
# server otherwise execs argv directly against its own restricted environment, which loses
# mise PATH and breaks shebangs like `#!/usr/bin/env node` (kills `codex` with exit 127).
#
# Opt out via --no-login-shell for cases where you want the raw exec (e.g. spawning `bash`
# itself, or debugging the spawn path). Override the shell binary via --login-shell or
# HERDER_SPAWN_SHELL when $SHELL is wrong (e.g. testing zsh on a bash box).
if [[ "$LOGIN_SHELL" -eq 1 ]]; then
  inner_cmd=""
  for arg in "$AGENT" ${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"}; do
    inner_cmd+="$(printf '%q ' "$arg")"
  done
  inner="export HERDER_GUID=$(printf '%q' "$GUID") HERDER_ROLE=$(printf '%q' "$ROLE") HERDER_LABEL=$(printf '%q' "$LABEL"); exec ${inner_cmd}"
  argv=("$LOGIN_SHELL_BIN" -lic "$inner")
else
  argv=(env "HERDER_GUID=$GUID" "HERDER_ROLE=$ROLE" "HERDER_LABEL=$LABEL" "$AGENT" ${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"})
fi

set +e
START_JSON="$(herdr "${start_args[@]}" -- "${argv[@]}" 2>&1)"
START_RC=$?
set -e

if [[ $START_RC -ne 0 ]]; then
  printf 'herdr agent start failed:\n%s\n' "$START_JSON" >&2
  exit "$START_RC"
fi

# herdr returns: {"id":...,"result":{"agent":{...},"argv":[...],"type":"agent_started"}}
PANE_ID="$(printf '%s' "$START_JSON" | jq -r '.result.agent.pane_id // empty')"
WS_ID="$(printf '%s' "$START_JSON" | jq -r '.result.agent.workspace_id // empty')"
TAB_ID="$(printf '%s' "$START_JSON" | jq -r '.result.agent.tab_id // empty')"
TERM_ID="$(printf '%s' "$START_JSON" | jq -r '.result.agent.terminal_id // empty')"
RESOLVED_CWD="$(printf '%s' "$START_JSON" | jq -r '.result.agent.cwd // empty')"

[[ -n "$PANE_ID" ]] || { printf 'unexpected start payload: %s\n' "$START_JSON" >&2; exit 1; }

# --new-tab cleanup: close the tab's seed (root) shell so the agent is the tab's
# only pane. Identity-check the root pane by terminal_id before closing — pane ids
# can compact, so a bare pane-id close could hit the agent. After the close, ids in
# the tab compact, which may renumber the agent's pane, so re-resolve PANE_ID by the
# agent's durable terminal_id before it's used for the registry / prompt delivery.
ROOT_CLOSED=0
if [[ "$NEW_TAB" -eq 1 && -n "$ROOT_PANE_ID" && -n "$ROOT_TERM" ]]; then
  if [[ "$ROOT_TERM" == "$TERM_ID" ]]; then
    printf 'herder-spawn: refusing to close root pane — terminal_id matches the agent (%s)\n' "$TERM_ID" >&2
  else
    LIVE_ROOT_TERM="$(herdr pane get "$ROOT_PANE_ID" 2>/dev/null | jq -r '.result.pane.terminal_id // empty' 2>/dev/null || true)"
    if [[ "$LIVE_ROOT_TERM" == "$ROOT_TERM" ]]; then
      herdr pane close "$ROOT_PANE_ID" >/dev/null 2>&1 && ROOT_CLOSED=1
    else
      printf 'herder-spawn: skipped root-pane close — %s no longer holds terminal %s (now %s)\n' \
        "$ROOT_PANE_ID" "$ROOT_TERM" "${LIVE_ROOT_TERM:-gone}" >&2
    fi
  fi
  if [[ "$ROOT_CLOSED" -eq 1 ]]; then
    # Re-resolve the agent's pane_id by terminal_id after compaction.
    RERESOLVED="$(herdr pane list 2>/dev/null \
      | jq -r --arg t "$TERM_ID" '.result.panes[]? | select(.terminal_id==$t) | .pane_id' 2>/dev/null | head -n1)"
    [[ -n "$RERESOLVED" ]] && PANE_ID="$RERESOLVED"
  fi
fi

# Append registry record.
NOW_ISO="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
STARTED_BY="${HERDR_PANE_ID:-unknown}"
PROMPT_PRESENT=$([[ -n "$PROMPT" ]] && echo true || echo false)

# Construct argv JSON array carefully.
ARGV_JSON="$(printf '%s\n' "${argv[@]}" | jq -R . | jq -sc .)"
EXTRA_JSON="$(printf '%s\n' "${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"}" | jq -R . | jq -sc .)"

RECORD="$(jq -nc \
  --arg guid "$GUID" \
  --arg short "$SHORT" \
  --arg label "$LABEL" \
  --arg role "$ROLE" \
  --arg agent "$AGENT" \
  --argjson extra "$EXTRA_JSON" \
  --argjson argv "$ARGV_JSON" \
  --arg pane "$PANE_ID" \
  --arg ws "$WS_ID" \
  --arg tab "$TAB_ID" \
  --arg term "$TERM_ID" \
  --arg cwd "$RESOLVED_CWD" \
  --arg started_at "$NOW_ISO" \
  --arg started_by "$STARTED_BY" \
  --argjson prompt_present "$PROMPT_PRESENT" \
  '{guid:$guid, short_guid:$short, label:$label, role:$role, agent:$agent,
    extra_args:$extra, argv:$argv, pane_id:$pane, workspace_id:$ws, tab_id:$tab,
    terminal_id:$term, cwd:$cwd, started_at:$started_at, started_by_pane:$started_by,
    initial_prompt_present:$prompt_present, status:"active"}')"

printf '%s\n' "$RECORD" >>"$REGISTRY"

# --- readiness, including first-run modal clearing ------------------------------
# Two things make a freshly-spawned agent un-receptive in ways that silently eat
# an initial prompt:
#   * First-run trust/onboarding modals. claude shows "Is this a project you
#     created or one you trust?" on first run in an untrusted dir (every fresh
#     worktree counts) and --dangerously-skip-permissions does NOT dismiss it.
#     The modal's selector arrow ("❯ 1. Yes…") even spoofs the input sigil, so a
#     naive sigil match reports ready and the prompt is pasted into the modal.
#   * The integration reports idle/working before the input is truly receptive
#     (codex during MCP startup).
# await_ready clears the modals (accepting trust — we're spawning into the user's
# own dirs in autonomous mode at their request) and waits for a settled state
# with the real input sigil showing.

pane_text() {
  herdr agent read "$PANE_ID" --source recent-unwrapped --lines 40 2>/dev/null \
    | jq -r '.result.read.text // empty' 2>/dev/null || true
}
pane_status() {
  herdr agent list 2>/dev/null \
    | jq -r --arg p "$PANE_ID" '.result.agents[]? | select(.pane_id==$p) | .agent_status // empty' \
    | head -n1
}
# Match the first-run directory-trust / onboarding modals across agent versions.
# Anchored on the distinctive question phrasings (codex changed wording from
# "files in this folder" to "contents of this directory"; claude uses its own).
# These modals sit at status=idle, so detecting them by text is the only signal.
is_trust_modal() {
  grep -qE 'Do you trust the contents of this directory|Do you trust the files in this folder|Is this a project you created or one you trust|Yes, I trust this folder' <<<"$1"
}

MODAL_CLEARED=0
await_ready() {
  local text status prev="" waited=0
  while [[ $waited -lt $WAIT_TIMEOUT_MS ]]; do
    text="$(pane_text)"
    status="$(pane_status)"
    if is_trust_modal "$text"; then
      # A directory-trust modal is open. Accepting it is a real decision (codex
      # warns it raises prompt-injection risk), so we only auto-accept in
      # autonomous mode — the user pointed the agent at this dir and asked for a
      # hands-off agent. Under --safe we refuse to touch it and surface it (the
      # parent keys off this 'trust-modal-open' marker), so a stray character can
      # never silently confirm trust.
      if [[ "$SAFE" -eq 1 ]]; then
        printf 'trust-modal-open (blocked by --safe; accept it in the pane)'
        return 0
      fi
      herdr pane send-keys "$PANE_ID" Enter >/dev/null 2>&1 || true
      MODAL_CLEARED=1; prev=""
      sleep 0.8; waited=$((waited + 800)); continue
    fi
    # Receptive once there's no modal, the integration reports a settled
    # (non-busy) state, AND the pane output has stopped changing between reads.
    # The output-stability check matters: codex keeps printing boot chrome (MCP
    # warnings, tips) after it first reports idle, and pasting into that window
    # makes it clip the leading characters of the message. Waiting for two
    # identical reads means boot has quiesced and the input handler is attached.
    # An explicit --ready-match, if given, must also be present.
    if [[ "$status" == "idle" || "$status" == "done" ]] \
       && { [[ -z "$READY_MATCH" ]] || grep -qF -- "$READY_MATCH" <<<"$text"; }; then
      if [[ -n "$prev" && "$text" == "$prev" ]]; then
        printf 'status=%s,stable%s' "$status" "$([[ $MODAL_CLEARED -eq 1 ]] && printf ',trust-accepted')"
        return 0
      fi
      prev="$text"
    fi
    sleep 0.5; waited=$((waited + 500))
  done
  printf 'timeout(status=%s%s)' "${status:-unknown}" "$([[ $MODAL_CLEARED -eq 1 ]] && printf ',trust-accepted')"
  return 0
}

# Always settle the agent (accept trust modals etc.) so even prompt-less spawns
# are usable; skip only with --no-ready-wait. await_ready runs in a subshell, so
# we read its trust-blocked outcome back from the reason string.
READY_REASON=""
TRUST_BLOCKED=0
if [[ "$NO_READY_WAIT" -eq 1 ]]; then
  READY_REASON="ready-wait skipped (--no-ready-wait)"
else
  READY_REASON="$(await_ready)"
  [[ "$READY_REASON" == *trust-modal-open* ]] && TRUST_BLOCKED=1
  sleep "$(awk -v ms="$SETTLE_MS" 'BEGIN{printf "%.3f", ms/1000}')"
fi

# Send initial prompt if requested. Delivery is delegated to herder-send, which
# confirms the text actually landed (re-pasting if dropped), submits, and
# verifies via the agent's working-state — so a dropped prompt is reported as
# not-landed instead of being silently lost. If a trust modal is blocking
# (--safe), we refuse to send: pasting now would let stray characters confirm the
# trust prompt.
PROMPT_SENT=false
DELIVERY_RESULT="not_attempted"
if [[ -n "$PROMPT" && "$TRUST_BLOCKED" -eq 1 ]]; then
  DELIVERY_RESULT="blocked_trust_modal"
elif [[ -n "$PROMPT" ]]; then
  set +e
  SEND_JSON="$("$SCRIPT_DIR/herder-send" "$PANE_ID" "$PROMPT" --json 2>/dev/null)"
  SEND_RC=$?
  set -e
  if [[ -n "$SEND_JSON" ]]; then
    DELIVERY_RESULT="$(printf '%s' "$SEND_JSON" | jq -r '.verify // "unknown"' 2>/dev/null || echo unknown)"
  fi
  [[ "$SEND_RC" -eq 0 ]] && PROMPT_SENT=true
fi

# Human summary to stderr.
{
  printf 'spawned %s (%s) in pane %s (workspace %s)\n' "$LABEL" "$AGENT" "$PANE_ID" "$WS_ID"
  printf '  guid:   %s\n' "$GUID"
  printf '  cwd:    %s\n' "$RESOLVED_CWD"
  if [[ "$NEW_TAB" -eq 1 ]]; then
    if [[ "$ROOT_CLOSED" -eq 1 ]]; then
      printf '  tab:    %s (new, root shell closed; agent is sole pane)\n' "$TAB"
    else
      printf '  tab:    %s (new; WARNING: root shell NOT closed — spare pane may remain)\n' "$TAB"
    fi
  fi
  if [[ -n "$PERM_INJECTED" ]]; then
    printf '  perms:  %s (autonomous; pass --safe to opt out)\n' "$PERM_INJECTED"
  elif [[ "$SAFE" -eq 1 ]]; then
    printf '  perms:  --safe (agent default ask-mode)\n'
  fi
  if [[ -n "$PROMPT" ]]; then
    if $PROMPT_SENT; then
      printf '  prompt: sent (%d chars), ready: %s, verify: %s\n' "${#PROMPT}" "$READY_REASON" "$DELIVERY_RESULT"
    elif [[ "$DELIVERY_RESULT" == "blocked_trust_modal" ]]; then
      printf '  prompt: NOT sent — a directory-trust modal is open and --safe forbids auto-accepting it.\n'
      printf '          Accept it in the pane (focus + Enter), then: herder-send %s "<prompt>"\n' "$LABEL"
    else
      printf '  prompt: NOT confirmed (verify: %s, ready: %s) — read the pane before assuming it landed\n' "$DELIVERY_RESULT" "$READY_REASON"
    fi
  elif [[ "$TRUST_BLOCKED" -eq 1 ]]; then
    printf '  note:   directory-trust modal is open (--safe); accept it in the pane to use the agent\n'
  fi
} >&2

if [[ "$JSON_OUT" -eq 1 ]]; then
  # Enrich the registry record with delivery + permission outcome for the caller.
  printf '%s\n' "$RECORD" | jq -c \
    --argjson sent "$PROMPT_SENT" \
    --arg delivery "$DELIVERY_RESULT" \
    --arg perm "$PERM_INJECTED" \
    --argjson new_tab "$([[ "$NEW_TAB" -eq 1 ]] && echo true || echo false)" \
    --argjson root_closed "$([[ "$ROOT_CLOSED" -eq 1 ]] && echo true || echo false)" \
    '. + {prompt_sent:$sent, delivery_result:$delivery, perm_injected:$perm, new_tab:$new_tab, root_pane_closed:$root_closed}'
fi
