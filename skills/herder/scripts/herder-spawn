#!/usr/bin/env bash
# herder-spawn — spawn a named, GUID-tagged agent in a herdr pane and register it.
#
# Usage:
#   herder-spawn --role <role> --agent <claude|codex|bash|...> [--prompt TEXT | --prompt-file FILE]
#                [--split right|down] [--workspace ID | --from-pane PANE_ID] [--tab ID | --new-tab] [--cwd PATH]
#                [--team NAME] [--no-focus] [--safe] [--notify | --notify-to PANE] [--label-prefix STR] [--extra-arg ARG]... [--json]
#
# Launch-through-hcom + teams:
#   * hcom-capable agents (claude/codex/gemini) are launched THROUGH hcom via the
#     `hcom-launch` wrapper (`hcom <tool> --run-here --tag <role> ...`), so they bind to the message
#     bus from birth (hooks + pty). hcom is a HARD dependency for these agents (fails early if
#     absent). Non-hcom agents (bash, ...) exec raw and stay reachable over herdr keystrokes only.
#   * TEAM = a named bus (ringfencing). HCOM_DIR = $HERDER_TEAMS_ROOT/<team> (default root
#     ~/.hcom/teams); no --team = the global ~/.hcom bus (frictionless default for standing agents).
#     Team resolves from --team, else $HERDER_TEAM (the orchestrator's team), else global. The
#     resolved HCOM_DIR is PINNED into the child's PROCESS env at launch so it joins exactly this bus;
#     the wrapper's config-dir passthrough keeps auth on the REAL config dir even for an isolated team.
#   * The role is passed as the hcom `--tag`, so hcom names the instance `<role>-<random>` and
#     `@<role>-` fan-out addressing works. herder-spawn CAPTURES the assigned name (by correlating the
#     child's herdr pane_id to the hcom entry) and records `team`/`hcom_dir`/`hcom_name`/`hcom_tag` in
#     the registry — herder-send/list/wait/cull resolve GUID/label to that bus coordinate.
#   * Name capture is BEST-EFFORT: if it fails the spawn still succeeds and the agent stays reachable
#     over herdr keystrokes; the outcome is reported in the summary and the --json `hcom_capture` field.
#
# Tab placement:
#   * --tab <id>  places the agent in an existing tab (as a split alongside whatever is there).
#   * --new-tab   gives the agent its own fresh tab with NO spare shell. `herdr tab create` always
#                 seeds a tab with a default shell (root) pane, and `herdr agent start` always opens
#                 a NEW pane (even without --split), so a naive "tab create + agent start --tab"
#                 leaves the root shell behind. --new-tab creates the tab, spawns the agent into it,
#                 then closes the root shell (verifying its terminal_id first so it never closes the
#                 agent) and re-resolves the agent's pane_id by terminal_id after the close compacts
#                 ids. The tab is labelled with the agent's label. --new-tab and --tab are exclusive.
#
# Behavior:
#   1. Generates a short GUID and a label "<role>-<shortguid>".
#   2. PERMISSIONS: by default spawns agents in autonomous ("YOLO") mode so they don't stall on
#      approval prompts the herder can't see — claude gets --dangerously-skip-permissions, codex gets
#      --dangerously-bypass-approvals-and-sandbox. This is injected because `exec claude` bypasses the
#      user's shell alias (which is where skip-permissions usually lives), so spawned agents would
#      otherwise come up in ask-mode. Pass --safe to opt out, or pass your own permission flag via
#      --extra-arg (any recognised one suppresses the default).
#   3. Calls `herdr agent start <label> ...`, launching the agent inside a login+interactive shell —
#      `$SHELL -lic 'export HERDER_*...; exec <launch>'` — so PATH / mise activation / auth env are
#      sourced like a normal pane (opt out with --no-login-shell). <launch> for an hcom agent is
#      `hcom-launch <agent> --tag <role> [extra-args]` with HCOM_DIR pinned to the team bus; for a
#      non-hcom agent it is the raw `<agent> [extra-args]`.
#   4. After the agent settles, captures its hcom-assigned name and appends a JSONL record
#      (incl. team/hcom_dir/hcom_name/hcom_tag) to $HERDER_STATE_DIR/registry.jsonl.
#   5. If --prompt/--prompt-file is given, waits for the agent to become truly ready (sigil + idle +
#      settle) then delegates delivery to `herder-send` (verified). For CODEX, a long or multi-line
#      brief is staged to a file ($HERDER_STATE_DIR/briefs/<guid>.md) and only a one-line "read it"
#      pointer is sent over the wire — this dodges codex's paste-blob / "Create a plan?" overlay /
#      boot-clip pathologies entirely (see the staging block below). Claude gets the inline prompt.
#   6. Prints a human summary to stderr and a JSON record to stdout when --json is set.
#
# Notes:
#   * The agent binary must accept being invoked plainly (e.g. `codex`, `claude`). For wrappers, use --extra-arg.
#   * Initial-prompt delivery is verified by `herder-send`; if it can't confirm submission it reports
#     prompt: NOT confirmed rather than silently claiming success.
#   * NOTIFY-BACK: every spawned agent gets HERDER_SEND (absolute path to herder-send) exported into
#     its shell, so it can ring a peer regardless of $PATH or whether it loaded the herder skill —
#     the gap that made agents fall back to raw `herdr agent send` (which writes text WITHOUT
#     submitting it, so the ring silently never lands). --notify also exports HERDER_NOTIFY_TO (the
#     spawner's pane, or --notify-to PANE) AND appends a concrete ring command to the prompt, so a
#     finished worker rings the orchestrator instead of the orchestrator polling. The run-log block
#     stays the record; the ring is only a doorbell.

set -euo pipefail

die() { printf 'herder-spawn: %s\n' "$*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

[[ "${HERDR_ENV:-}" = "1" ]] || die "not running inside a herdr pane (HERDR_ENV != 1)"
have herdr || die "herdr not on PATH"
have jq || die "jq not on PATH"
have uuidgen || die "uuidgen not on PATH"

ROLE=""
AGENT=""
PROMPT=""
PROMPT_FILE=""
SPLIT="right"
WORKSPACE=""
FROM_PANE=""
TAB=""
NEW_TAB=0
CWD=""
FOCUS_FLAG="--no-focus"
LABEL_PREFIX=""
EXTRA_ARGS=()
JSON_OUT=0
WAIT_TIMEOUT_MS="${HERDER_SPAWN_WAIT_MS:-15000}"
READY_MATCH=""
NO_READY_WAIT=0
LOGIN_SHELL=1
LOGIN_SHELL_BIN="${HERDER_SPAWN_SHELL:-${SHELL:-/bin/bash}}"
SAFE=0
NOTIFY=0
NOTIFY_TO=""
SETTLE_MS="${HERDER_SPAWN_SETTLE_MS:-1500}"
# Team (D7): a team is a named bus. HCOM_DIR = $HERDER_TEAMS_ROOT/<team>; empty team = the global
# ~/.hcom bus (frictionless default for standing agents). --team wins, else inherit the orchestrator's
# $HERDER_TEAM, else global. The child's HCOM_DIR is resolved + PINNED at launch so herder's registry
# matches the child's real bus; herder-send/list/wait/cull later scope by the recorded team bus.
TEAM="${HERDER_TEAM:-}"
HERDER_TEAMS_ROOT="${HERDER_TEAMS_ROOT:-$HOME/.hcom/teams}"

# Sibling scripts live next to this one; resolve their dir so we can delegate
# initial-prompt delivery to herder-send (verified send) regardless of $PATH.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Shared libs (sourced here, before arg validation, because both are needed early:
# trust-modals.sh gives the modal ERE used by is_trust_modal (same pattern the
# send-path preflight in driver-herdr.sh uses — one source of truth), and
# hcom-tools.sh gives is_hcom_capable, which the ROLE-as-hcom-tag validation below
# needs the moment $AGENT is known.
source "$SCRIPT_DIR/lib/trust-modals.sh"
source "$SCRIPT_DIR/lib/hcom-tools.sh"

# Per-agent default permission flag. We inject this so spawned agents come up in
# autonomous mode (the herder can't see or answer an approval modal in a child
# pane). `exec <agent>` bypasses the user's shell alias, so without this claude
# spawns in ask-mode even when the user's interactive `claude` is aliased to
# --dangerously-skip-permissions.
default_perm_flag() {
  case "$1" in
    claude) printf '%s' '--dangerously-skip-permissions';;
    codex)  printf '%s' '--dangerously-bypass-approvals-and-sandbox';;
    *)      printf '';;
  esac
}

# Does the caller's --extra-arg list already carry a permission-shaping flag? If
# so, respect it and don't inject our default.
has_explicit_perm_flag() {
  local a
  for a in ${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"}; do
    case "$a" in
      # claude
      --dangerously-skip-permissions|--permission-mode|--permission-prompt-tool) return 0;;
      # codex
      --dangerously-bypass-approvals-and-sandbox|--full-auto|-a|--ask-for-approval|-s|--sandbox) return 0;;
    esac
  done
  return 1
}


while [[ $# -gt 0 ]]; do
  case "$1" in
    --role) ROLE="$2"; shift 2;;
    --agent) AGENT="$2"; shift 2;;
    --prompt) PROMPT="$2"; shift 2;;
    --prompt-file) PROMPT_FILE="$2"; shift 2;;
    --split) SPLIT="$2"; shift 2;;
    --workspace) WORKSPACE="$2"; shift 2;;
    --from-pane) FROM_PANE="$2"; shift 2;;
    --tab) TAB="$2"; shift 2;;
    --new-tab) NEW_TAB=1; shift;;
    --cwd) CWD="$2"; shift 2;;
    --focus) FOCUS_FLAG="--focus"; shift;;
    --no-focus) FOCUS_FLAG="--no-focus"; shift;;
    --label-prefix) LABEL_PREFIX="$2"; shift 2;;
    --extra-arg) EXTRA_ARGS+=("$2"); shift 2;;
    --json) JSON_OUT=1; shift;;
    --wait-timeout-ms) WAIT_TIMEOUT_MS="$2"; shift 2;;
    --ready-match) READY_MATCH="$2"; shift 2;;
    --no-ready-wait) NO_READY_WAIT=1; shift;;
    --no-login-shell) LOGIN_SHELL=0; shift;;
    --login-shell) LOGIN_SHELL_BIN="$2"; shift 2;;
    --safe) SAFE=1; shift;;
    --team) TEAM="$2"; shift 2;;
    --notify) NOTIFY=1; shift;;
    --notify-to) NOTIFY=1; NOTIFY_TO="$2"; shift 2;;
    -h|--help) sed -n '2,68p' "$0"; exit 0;;
    *) die "unknown arg: $1";;
  esac
done

[[ -n "$ROLE" ]] || die "--role required"
[[ -n "$AGENT" ]] || die "--agent required"
# Team name (if any) must be a single safe path segment — it becomes a bus dir under the teams root.
[[ -z "$TEAM" || "$TEAM" =~ ^[A-Za-z0-9._-]+$ ]] || die "--team must be a single safe path segment (letters/digits/._- only): $TEAM"
# For hcom-capable agents ROLE is passed straight to hcom as the --tag, and hcom
# rejects tags with anything but letters, digits, and hyphens ("tag can only contain
# letters, numbers, and hyphens") — a role like `phase_3` would otherwise die
# cryptically INSIDE the spawned pane. Catch it here (needs is_hcom_capable + $AGENT,
# both live now that the lib is sourced above).
if is_hcom_capable "$AGENT"; then
  [[ "$ROLE" =~ ^[A-Za-z0-9-]+$ ]] || die "--role must contain only letters, digits, and hyphens (it becomes the hcom --tag): $ROLE"
fi
[[ -z "$PROMPT" || -z "$PROMPT_FILE" ]] || die "use --prompt or --prompt-file, not both"
[[ -z "$WORKSPACE" || -z "$FROM_PANE" ]] || die "use --workspace or --from-pane, not both"
[[ "$NEW_TAB" -eq 0 || -z "$TAB" ]] || die "use --new-tab or --tab, not both"

# Resolve --from-pane → its workspace_id, so the new pane lands in the same
# workspace as the named parent (not wherever focus happens to be).
if [[ -n "$FROM_PANE" ]]; then
  FROM_PANE_JSON="$(herdr pane get "$FROM_PANE" 2>&1 || true)"
  WORKSPACE="$(printf '%s' "$FROM_PANE_JSON" | jq -r '.result.pane.workspace_id // empty' 2>/dev/null || true)"
  [[ -n "$WORKSPACE" ]] || die "--from-pane $FROM_PANE: pane not found (herdr pane get returned: $FROM_PANE_JSON)"
fi

# Validate --workspace against the live workspace list before calling agent start.
# Herdr workspace ids are session-live; after a herdr restart they all change, and
# a stale id surfaces as a cryptic `agent_placement_not_found` JSON error. Fail
# early with a clear message instead.
if [[ -n "$WORKSPACE" ]]; then
  WS_LIST_JSON="$(herdr workspace list 2>&1 || true)"
  WS_HIT="$(printf '%s' "$WS_LIST_JSON" | jq -r --arg ws "$WORKSPACE" \
    '.result.workspaces[]? | select(.workspace_id==$ws) | .workspace_id' 2>/dev/null || true)"
  if [[ -z "$WS_HIT" ]]; then
    {
      printf 'herder-spawn: --workspace %s not found in live workspace list.\n' "$WORKSPACE"
      printf 'Herdr workspace ids are session-live; they change after a herdr restart.\n'
      printf 'Live workspaces:\n'
      printf '%s' "$WS_LIST_JSON" | jq -r '.result.workspaces[]? | "  \(.workspace_id)  \(.label // "(no label)")  \(.worktree.checkout_path // .worktree.repo_root // "")"' 2>/dev/null || true
    } >&2
    exit 2
  fi
fi

if [[ -n "$PROMPT_FILE" ]]; then
  [[ -r "$PROMPT_FILE" ]] || die "prompt file not readable: $PROMPT_FILE"
  PROMPT="$(cat "$PROMPT_FILE")"
fi

# Notify-back wiring. HERDER_SEND (absolute path to the verified-send helper) is
# exported into every child regardless of --notify, so any agent can ring a peer
# without the helper being on its $PATH or having loaded the herder skill — the
# discoverability gap that drove agents to raw `herdr agent send` (no Enter → the
# ring silently never submits). --notify additionally resolves a ring target
# (default: the spawner's pane) and appends a concrete ring command to the prompt.
HERDER_SEND_ABS="$SCRIPT_DIR/herder-send"
if [[ "$NOTIFY" -eq 1 && -z "$NOTIFY_TO" ]]; then
  # Default ring target = the spawner (this orchestrator pane). Inject its DURABLE
  # terminal_id, not the raw HERDR_PANE_ID: herdr compacts pane_ids as sibling panes
  # close, so a bare pane_id baked into the child's prompt can later ring whoever now
  # sits at that pane. herdr exposes only HERDR_PANE_ID to a pane, so we look it up
  # via `herdr pane get` to get our own terminal_id. NOTE: HERDR_PANE_ID is the
  # `p_<n>` alias form (e.g. p_324), which `herdr pane list` does NOT emit (it
  # reports `w…-N` ids) — so we must resolve it with `pane get`, which accepts both
  # forms, not by scanning the list. herder-send then resolves the resulting term_*
  # target to its current pane at ring time (and refuses if gone) — the same
  # drift-proofing the guid/label path gets. Fall back to the raw pane only if the
  # terminal_id can't be resolved.
  if [[ -n "${HERDR_PANE_ID:-}" ]]; then
    NOTIFY_TO="$(herdr pane get "$HERDR_PANE_ID" 2>/dev/null | jq -r '.result.pane.terminal_id // empty' 2>/dev/null || true)"
    if [[ -z "$NOTIFY_TO" ]]; then
      NOTIFY_TO="$HERDR_PANE_ID"
      printf 'herder-spawn: could not resolve spawner terminal_id; ring target falls back to raw pane %s (drift-prone)\n' "$HERDR_PANE_ID" >&2
    fi
  else
    printf 'herder-spawn: --notify set but HERDR_PANE_ID is empty; no ring target injected\n' >&2
  fi
fi
if [[ "$NOTIFY" -eq 1 && -n "$PROMPT" && -n "$NOTIFY_TO" ]]; then
  PROMPT="$PROMPT

When your unit is finished and your run-log DONE/BLOCKED block is written, ring the orchestrator so it does not have to poll (the run-log block is the record — this is only a doorbell):
  $HERDER_SEND_ABS $NOTIFY_TO 'Unit DONE — run-log updated'
Ring exactly ONCE and then stop, whatever it reports. The orchestrator is usually mid-turn when you ring, so the helper will say verify=queued (or even verify=not_delivered) — that is EXPECTED and is NOT a failure: your message is queued and the run-log is the real record. Do NOT resend on a queued/not_delivered result; resending just stacks duplicate messages in the orchestrator's queue.
Do NOT ring with raw 'herdr agent send' — it writes the text without submitting it, so the ring never lands. Use the command above (also available as \"\$HERDER_SEND\" \"\$HERDER_NOTIFY_TO\")."
fi

# Inject the autonomous-mode permission flag unless --safe or the caller already
# passed one. Prepend so an explicit later --extra-arg still wins if it conflicts.
PERM_INJECTED=""
if [[ "$SAFE" -eq 0 ]]; then
  PERM_FLAG="$(default_perm_flag "$AGENT")"
  if [[ -n "$PERM_FLAG" ]] && ! has_explicit_perm_flag; then
    EXTRA_ARGS=("$PERM_FLAG" ${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"})
    PERM_INJECTED="$PERM_FLAG"
  fi
fi

STATE_DIR="${HERDER_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/herder}"
mkdir -p "$STATE_DIR"
REGISTRY="$STATE_DIR/registry.jsonl"

# Generate IDs. Full UUID is the canonical handle; short form is for human labels.
GUID="$(uuidgen | tr 'A-Z' 'a-z')"
SHORT="${GUID%%-*}"
LABEL="${LABEL_PREFIX}${ROLE}-${SHORT}"

# --- launch-through-hcom + team resolution (W2) --------------------------------
# hcom-capable agents launch THROUGH hcom (via the hcom-launch wrapper) so they bind
# to the bus from birth; non-hcom agents (bash, ...) exec raw and stay keystroke-only.
# The capable set (claude/codex/gemini) lives in lib/hcom-tools.sh — opencode is
# deliberately excluded there (its config-dir passthrough under hcom's local-mode
# OPENCODE_CONFIG_DIR redirect is unverified), so it spawns raw/keystroke-only.
IS_HCOM_AGENT=0
is_hcom_capable "$AGENT" && IS_HCOM_AGENT=1
HCOM_LAUNCH="$SCRIPT_DIR/hcom-launch"

# hcom is a HARD dependency for hcom-capable agents (D6/R4). Fail early + clearly
# rather than letting the wrapper die inside the pane (which would just time out at
# readiness). bash and other non-hcom agents never need hcom.
if [[ "$IS_HCOM_AGENT" -eq 1 ]]; then
  have hcom || die "hcom is required to spawn '$AGENT' (launch-through-hcom); install hcom or spawn --agent bash"
  [[ -x "$HCOM_LAUNCH" ]] || die "hcom-launch wrapper missing/not executable: $HCOM_LAUNCH"
fi

# Resolve the child's TEAM bus (D7). team → $HERDER_TEAMS_ROOT/<team>; empty → the
# global ~/.hcom bus. We PIN this HCOM_DIR into the child's launch env so the child
# joins exactly this bus and herder's registry matches its reality (no drift). The
# W1 wrapper's config-dir passthrough keeps auth real even for an isolated team dir.
if [[ -n "$TEAM" ]]; then
  HCOM_DIR_EFF="$HERDER_TEAMS_ROOT/$TEAM"
  mkdir -p "$HCOM_DIR_EFF" 2>/dev/null || true
else
  HCOM_DIR_EFF="$HOME/.hcom"
fi

# Resolve the child's cwd up front (used for capture correlation + reporting). Order
# mirrors how herdr resolves the pane cwd: explicit --cwd, else the target
# workspace's checkout, else this (spawner's) cwd.
CHILD_CWD="$CWD"
if [[ -z "$CHILD_CWD" && -n "$WORKSPACE" && -n "${WS_LIST_JSON:-}" ]]; then
  CHILD_CWD="$(printf '%s' "$WS_LIST_JSON" | jq -r --arg ws "$WORKSPACE" \
    '.result.workspaces[]? | select(.workspace_id==$ws) | (.worktree.checkout_path // .worktree.repo_root // "")' 2>/dev/null || true)"
fi
[[ -n "$CHILD_CWD" ]] || CHILD_CWD="$PWD"

# --new-tab: create a dedicated tab for this agent with no spare shell. `tab create`
# seeds the tab with a root shell pane; we capture its pane_id + terminal_id so we
# can close it after the agent lands (see post-start cleanup below). Set TAB so the
# normal `agent start --tab` path places the agent in this tab.
ROOT_PANE_ID=""
ROOT_TERM=""
if [[ "$NEW_TAB" -eq 1 ]]; then
  tab_args=("tab" "create" "--no-focus" "--label" "$LABEL")
  [[ -n "$WORKSPACE" ]] && tab_args+=("--workspace" "$WORKSPACE")
  [[ -n "$CWD" ]]       && tab_args+=("--cwd" "$CWD")
  set +e
  TAB_CREATE_JSON="$(herdr "${tab_args[@]}" 2>&1)"
  TAB_CREATE_RC=$?
  set -e
  if [[ $TAB_CREATE_RC -ne 0 ]]; then
    printf 'herdr tab create failed:\n%s\n' "$TAB_CREATE_JSON" >&2
    exit "$TAB_CREATE_RC"
  fi
  TAB="$(printf '%s' "$TAB_CREATE_JSON" | jq -r '.result.tab.tab_id // empty')"
  ROOT_PANE_ID="$(printf '%s' "$TAB_CREATE_JSON" | jq -r '.result.root_pane.pane_id // empty')"
  ROOT_TERM="$(printf '%s' "$TAB_CREATE_JSON" | jq -r '.result.root_pane.terminal_id // empty')"
  [[ -n "$TAB" && -n "$ROOT_PANE_ID" ]] || { printf 'unexpected tab create payload: %s\n' "$TAB_CREATE_JSON" >&2; exit 1; }
fi

# Build herdr agent start arg list.
start_args=("agent" "start" "$LABEL" "$FOCUS_FLAG" "--split" "$SPLIT")
[[ -n "$WORKSPACE" ]] && start_args+=("--workspace" "$WORKSPACE")
[[ -n "$TAB" ]]       && start_args+=("--tab" "$TAB")
[[ -n "$CWD" ]]       && start_args+=("--cwd" "$CWD")

# argv: how we invoke the agent in the new pane.
#
# Default path: wrap in the user's login+interactive shell so PATH, mise activation, auth env,
# etc. are sourced from .zshrc/.bashrc/.zprofile the same way Cmd+D-style panes are. The herdr
# server otherwise execs argv directly against its own restricted environment, which loses
# mise PATH and breaks shebangs like `#!/usr/bin/env node` (kills `codex` with exit 127).
#
# Opt out via --no-login-shell for cases where you want the raw exec (e.g. spawning `bash`
# itself, or debugging the spawn path). Override the shell binary via --login-shell or
# HERDER_SPAWN_SHELL when $SHELL is wrong (e.g. testing zsh on a bash box).
NOTIFY_TO_EXPORT=""
[[ -n "$NOTIFY_TO" ]] && NOTIFY_TO_EXPORT=" HERDER_NOTIFY_TO=$(printf '%q' "$NOTIFY_TO")"

# Launch command: hcom-capable agents go THROUGH the hcom-launch wrapper with the
# role as the hcom --tag (fan-out addressing; hcom assigns <role>-<random>, which we
# capture below); non-hcom agents exec raw. The child's HCOM_DIR is PINNED to the
# resolved team bus (D7) in its PROCESS env — exported AFTER the login shell sources
# rc/mise so our pin wins, so the child joins exactly this bus. The wrapper's W1
# config-dir passthrough keeps auth real even for an isolated team dir.
LAUNCH_TOKENS=()
if [[ "$IS_HCOM_AGENT" -eq 1 ]]; then
  LAUNCH_TOKENS=("$HCOM_LAUNCH" "$AGENT" --tag "$ROLE" ${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"})
else
  LAUNCH_TOKENS=("$AGENT" ${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"})
fi
HCOM_ENV=""
[[ "$IS_HCOM_AGENT" -eq 1 ]] && HCOM_ENV=" HCOM_DIR=$(printf '%q' "$HCOM_DIR_EFF")"
if [[ "$LOGIN_SHELL" -eq 1 ]]; then
  inner_cmd=""
  for arg in "${LAUNCH_TOKENS[@]}"; do
    inner_cmd+="$(printf '%q ' "$arg")"
  done
  inner="export HERDER_GUID=$(printf '%q' "$GUID") HERDER_ROLE=$(printf '%q' "$ROLE") HERDER_LABEL=$(printf '%q' "$LABEL") HERDER_SEND=$(printf '%q' "$HERDER_SEND_ABS")${NOTIFY_TO_EXPORT}${HCOM_ENV}; exec ${inner_cmd}"
  argv=("$LOGIN_SHELL_BIN" -lic "$inner")
else
  argv=(env "HERDER_GUID=$GUID" "HERDER_ROLE=$ROLE" "HERDER_LABEL=$LABEL" "HERDER_SEND=$HERDER_SEND_ABS")
  [[ -n "$NOTIFY_TO" ]] && argv+=("HERDER_NOTIFY_TO=$NOTIFY_TO")
  [[ "$IS_HCOM_AGENT" -eq 1 ]] && argv+=("HCOM_DIR=$HCOM_DIR_EFF")
  argv+=("${LAUNCH_TOKENS[@]}")
fi

set +e
START_JSON="$(herdr "${start_args[@]}" -- "${argv[@]}" 2>&1)"
START_RC=$?
set -e

if [[ $START_RC -ne 0 ]]; then
  printf 'herdr agent start failed:\n%s\n' "$START_JSON" >&2
  exit "$START_RC"
fi

# herdr returns: {"id":...,"result":{"agent":{...},"argv":[...],"type":"agent_started"}}
PANE_ID="$(printf '%s' "$START_JSON" | jq -r '.result.agent.pane_id // empty')"
WS_ID="$(printf '%s' "$START_JSON" | jq -r '.result.agent.workspace_id // empty')"
TAB_ID="$(printf '%s' "$START_JSON" | jq -r '.result.agent.tab_id // empty')"
TERM_ID="$(printf '%s' "$START_JSON" | jq -r '.result.agent.terminal_id // empty')"
RESOLVED_CWD="$(printf '%s' "$START_JSON" | jq -r '.result.agent.cwd // empty')"
# Physical (symlink-resolved) form of the cwd. On macOS the same dir can surface as
# /tmp/... vs /private/tmp/... depending on who reports it, so the hcom capture
# fallback matches .directory against EITHER form. Fall back to the logical path if
# the dir isn't reachable (e.g. already torn down).
RESOLVED_CWD_PHYS="$(cd "$RESOLVED_CWD" 2>/dev/null && pwd -P || printf '%s' "$RESOLVED_CWD")"

[[ -n "$PANE_ID" ]] || { printf 'unexpected start payload: %s\n' "$START_JSON" >&2; exit 1; }

# Freeze the pane_id as it was AT LAUNCH. hcom recorded THIS value in the child's env
# (HERDR_PANE_ID == .result.agent.pane_id) and stamped it into launch_context.pane_id.
# It survives compaction precisely because it is frozen: the --new-tab cleanup below
# closes the seed root pane, herdr compacts ids, and PANE_ID gets re-resolved to the
# NEW id — so the hcom-name capture MUST correlate on this frozen value, not the
# re-resolved PANE_ID (which can never match launch_context after compaction).
LAUNCH_PANE_ID="$PANE_ID"

# --new-tab cleanup: close the tab's seed (root) shell so the agent is the tab's
# only pane. Identity-check the root pane by terminal_id before closing — pane ids
# can compact, so a bare pane-id close could hit the agent. After the close, ids in
# the tab compact, which may renumber the agent's pane, so re-resolve PANE_ID by the
# agent's durable terminal_id before it's used for the registry / prompt delivery.
ROOT_CLOSED=0
if [[ "$NEW_TAB" -eq 1 && -n "$ROOT_PANE_ID" && -n "$ROOT_TERM" ]]; then
  if [[ "$ROOT_TERM" == "$TERM_ID" ]]; then
    printf 'herder-spawn: refusing to close root pane — terminal_id matches the agent (%s)\n' "$TERM_ID" >&2
  else
    LIVE_ROOT_TERM="$(herdr pane get "$ROOT_PANE_ID" 2>/dev/null | jq -r '.result.pane.terminal_id // empty' 2>/dev/null || true)"
    if [[ "$LIVE_ROOT_TERM" == "$ROOT_TERM" ]]; then
      herdr pane close "$ROOT_PANE_ID" >/dev/null 2>&1 && ROOT_CLOSED=1
    else
      printf 'herder-spawn: skipped root-pane close — %s no longer holds terminal %s (now %s)\n' \
        "$ROOT_PANE_ID" "$ROOT_TERM" "${LIVE_ROOT_TERM:-gone}" >&2
    fi
  fi
  if [[ "$ROOT_CLOSED" -eq 1 ]]; then
    # Re-resolve the agent's pane_id by terminal_id after compaction.
    RERESOLVED="$(herdr pane list 2>/dev/null \
      | jq -r --arg t "$TERM_ID" '.result.panes[]? | select(.terminal_id==$t) | .pane_id' 2>/dev/null | head -n1)"
    [[ -n "$RERESOLVED" ]] && PANE_ID="$RERESOLVED"
  fi
fi

# Append registry record.
NOW_ISO="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
STARTED_BY="${HERDR_PANE_ID:-unknown}"
PROMPT_PRESENT=$([[ -n "$PROMPT" ]] && echo true || echo false)

# Construct argv JSON array carefully. The full registry record is built + appended
# AFTER the agent settles and its hcom name is captured (W2), so the persisted row
# carries the durable (team, hcom_dir, hcom_name, hcom_tag) identity, not just a name-
# less placeholder — herder-send/list/wait/cull (W3) resolve through those fields.
ARGV_JSON="$(printf '%s\n' "${argv[@]}" | jq -R . | jq -sc .)"
EXTRA_JSON="$(printf '%s\n' "${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"}" | jq -R . | jq -sc .)"

# --- readiness, including first-run modal clearing ------------------------------
# Two things make a freshly-spawned agent un-receptive in ways that silently eat
# an initial prompt:
#   * First-run trust/onboarding modals. claude shows "Is this a project you
#     created or one you trust?" on first run in an untrusted dir (every fresh
#     worktree counts) and --dangerously-skip-permissions does NOT dismiss it.
#     The modal's selector arrow ("❯ 1. Yes…") even spoofs the input sigil, so a
#     naive sigil match reports ready and the prompt is pasted into the modal.
#   * The integration reports idle/working before the input is truly receptive
#     (codex during MCP startup).
# await_ready clears the modals (accepting trust — we're spawning into the user's
# own dirs in autonomous mode at their request) and waits for a settled state
# with the real input sigil showing.

pane_text() {
  herdr agent read "$PANE_ID" --source recent-unwrapped --lines 40 2>/dev/null \
    | jq -r '.result.read.text // empty' 2>/dev/null || true
}
pane_status() {
  herdr agent list 2>/dev/null \
    | jq -r --arg p "$PANE_ID" '.result.agents[]? | select(.pane_id==$p) | .agent_status // empty' \
    | head -n1
}
# Match the first-run directory-trust / onboarding modals across agent versions.
# The pattern lives in lib/trust-modals.sh (HERDER_TRUST_MODAL_ERE) so this detector
# and the send-path preflight in driver-herdr.sh stay in lockstep — one source of
# truth for the phrasings (codex changed wording from "files in this folder" to
# "contents of this directory"; claude uses its own). These modals sit at
# status=idle, so detecting them by text is the only signal.
is_trust_modal() {
  grep -qE "$HERDER_TRUST_MODAL_ERE" <<<"$1"
}

MODAL_CLEARED=0
await_ready() {
  local text status prev="" waited=0
  while [[ $waited -lt $WAIT_TIMEOUT_MS ]]; do
    text="$(pane_text)"
    status="$(pane_status)"
    if is_trust_modal "$text"; then
      # A directory-trust modal is open. Accepting it is a real decision (codex
      # warns it raises prompt-injection risk), so we only auto-accept in
      # autonomous mode — the user pointed the agent at this dir and asked for a
      # hands-off agent. Under --safe we refuse to touch it and surface it (the
      # parent keys off this 'trust-modal-open' marker), so a stray character can
      # never silently confirm trust.
      if [[ "$SAFE" -eq 1 ]]; then
        printf 'trust-modal-open (blocked by --safe; accept it in the pane)'
        return 0
      fi
      herdr pane send-keys "$PANE_ID" Enter >/dev/null 2>&1 || true
      MODAL_CLEARED=1; prev=""
      sleep 0.8; waited=$((waited + 800)); continue
    fi
    # Receptive once there's no modal, the integration reports a settled
    # (non-busy) state, AND the pane output has stopped changing between reads.
    # The output-stability check matters: codex keeps printing boot chrome (MCP
    # warnings, tips) after it first reports idle, and pasting into that window
    # makes it clip the leading characters of the message. Waiting for two
    # identical reads means boot has quiesced and the input handler is attached.
    # An explicit --ready-match, if given, must also be present.
    if [[ "$status" == "idle" || "$status" == "done" ]] \
       && { [[ -z "$READY_MATCH" ]] || grep -qF -- "$READY_MATCH" <<<"$text"; }; then
      if [[ -n "$prev" && "$text" == "$prev" ]]; then
        printf 'status=%s,stable%s' "$status" "$([[ $MODAL_CLEARED -eq 1 ]] && printf ',trust-accepted')"
        return 0
      fi
      prev="$text"
    fi
    sleep 0.5; waited=$((waited + 500))
  done
  printf 'timeout(status=%s%s)' "${status:-unknown}" "$([[ $MODAL_CLEARED -eq 1 ]] && printf ',trust-accepted')"
  return 0
}

# Always settle the agent (accept trust modals etc.) so even prompt-less spawns
# are usable; skip only with --no-ready-wait. await_ready runs in a subshell, so
# we read its trust-blocked outcome back from the reason string.
READY_REASON=""
TRUST_BLOCKED=0
if [[ "$NO_READY_WAIT" -eq 1 ]]; then
  READY_REASON="ready-wait skipped (--no-ready-wait)"
else
  READY_REASON="$(await_ready)"
  [[ "$READY_REASON" == *trust-modal-open* ]] && TRUST_BLOCKED=1
  sleep "$(awk -v ms="$SETTLE_MS" 'BEGIN{printf "%.3f", ms/1000}')"
fi

# Send initial prompt if requested. Delivery is delegated to herder-send, which
# confirms the text actually landed (re-pasting if dropped), submits, and
# verifies via the agent's working-state — so a dropped prompt is reported as
# not-landed instead of being silently lost. If a trust modal is blocking
# (--safe), we refuse to send: pasting now would let stray characters confirm the
# trust prompt.
PROMPT_SENT=false
DELIVERY_RESULT="not_attempted"

# Codex mishandles long / multi-line pastes THREE ways, and only one is the
# "[Pasted Content]" blob (>~1k chars) that needs a fragile, codex-version-specific
# double-Enter to submit: a multi-line paste also trips codex's "Create a plan?"
# overlay (codex then acts on only the tail), and leading characters clip during
# boot. A short single-line pointer sidesteps all three at once — no blob, no
# overlay, no clip, one clean Enter — so it is the DURABLE fix, not the per-version
# Enter dance. For codex we therefore stage a long / multi-line brief to a file and
# send a one-line "read it" pointer instead of the brief itself. Claude has none of
# these pathologies, so it always gets the inline prompt. (This makes the manual
# discipline in SKILL.md the default; the --notify appendix alone makes a prompt
# multi-line, which is exactly the overlay trigger.)
WIRE_PAYLOAD="$PROMPT"
BRIEF_FILE=""
if [[ -n "$PROMPT" && "$AGENT" = "codex" ]] \
   && { [[ "$PROMPT" == *$'\n'* ]] || [[ "${#PROMPT}" -gt 800 ]]; }; then
  BRIEF_DIR="$STATE_DIR/briefs"
  mkdir -p "$BRIEF_DIR"
  BRIEF_FILE="$BRIEF_DIR/$GUID.md"
  printf '%s\n' "$PROMPT" >"$BRIEF_FILE"
  WIRE_PAYLOAD="Read $BRIEF_FILE in full (it is your complete brief), then plan before writing code."
fi

if [[ -n "$PROMPT" && "$TRUST_BLOCKED" -eq 1 ]]; then
  DELIVERY_RESULT="blocked_trust_modal"
elif [[ -n "$PROMPT" ]]; then
  set +e
  SEND_JSON="$("$SCRIPT_DIR/herder-send" "$PANE_ID" "$WIRE_PAYLOAD" --json 2>/dev/null)"
  SEND_RC=$?
  set -e
  if [[ -n "$SEND_JSON" ]]; then
    DELIVERY_RESULT="$(printf '%s' "$SEND_JSON" | jq -r '.verify // "unknown"' 2>/dev/null || echo unknown)"
  fi
  [[ "$SEND_RC" -eq 0 ]] && PROMPT_SENT=true
fi

# --- capture the hcom name (W2) + append the registry record -------------------
# The child launched THROUGH hcom (hcom-launch), so it is already bus-bound; hcom
# assigned it <role>-<random>. Correlate the child's herdr pane_id to the hcom entry
# in the resolved team bus to read that name. pane_id is a TRANSIENT key (herdr
# compacts it on close), so we correlate NOW (immediately, pre-compaction) and PERSIST
# the durable hcom_name — never pane_id. Best-effort: if capture fails the agent is
# still reachable over herdr keystrokes; herder-send just can't route it over the bus.
HCOM_NAME=""
HCOM_CAPTURE="not_hcom_agent"
if [[ "$IS_HCOM_AGENT" -eq 1 ]]; then
  HCOM_CAPTURE="not_found"
  cap_tries=0
  while [[ $cap_tries -lt 6 ]]; do
    LIST_JSON="$(HCOM_DIR="$HCOM_DIR_EFF" hcom list --json 2>/dev/null || true)"
    if [[ -n "$LIST_JSON" ]]; then
      # primary: the exact herdr pane_id hcom recorded in launch_context (unique per
      # spawn). Correlate on LAUNCH_PANE_ID — the value frozen at launch, which is what
      # hcom stamped into launch_context — NOT the possibly re-resolved PANE_ID.
      HCOM_NAME="$(printf '%s' "$LIST_JSON" | jq -r --arg p "$LAUNCH_PANE_ID" \
        'map(select(.launch_context.pane_id==$p)) | (.[0].name // empty)' 2>/dev/null || true)"
      # fallback: same role tag + same cwd, newest by created_at. hcom's .directory may
      # report the physical path (/private/tmp/...) while RESOLVED_CWD is the symlinked
      # form (/tmp/...) on macOS, so match against EITHER the logical or physical cwd.
      if [[ -z "$HCOM_NAME" ]]; then
        HCOM_NAME="$(printf '%s' "$LIST_JSON" | jq -r --arg tag "$ROLE" --arg dir "$RESOLVED_CWD" --arg dirp "$RESOLVED_CWD_PHYS" \
          'map(select(.tag==$tag and (.directory==$dir or .directory==$dirp))) | sort_by(.created_at) | (.[-1].name // empty)' 2>/dev/null || true)"
      fi
      [[ -n "$HCOM_NAME" ]] && { HCOM_CAPTURE="captured"; break; }
    fi
    cap_tries=$((cap_tries + 1))
    sleep 0.7
  done
fi

# Identity fields: only hcom agents carry a bus identity. team is recorded as intent
# regardless (empty = global bus); hcom_dir/name/tag are the bus coordinate W3 sends to.
HCOM_DIR_REC=""; HCOM_TAG_REC=""
if [[ "$IS_HCOM_AGENT" -eq 1 ]]; then HCOM_DIR_REC="$HCOM_DIR_EFF"; HCOM_TAG_REC="$ROLE"; fi

RECORD="$(jq -nc \
  --arg guid "$GUID" --arg short "$SHORT" --arg label "$LABEL" --arg role "$ROLE" --arg agent "$AGENT" \
  --argjson extra "$EXTRA_JSON" --argjson argv "$ARGV_JSON" \
  --arg pane "$PANE_ID" --arg ws "$WS_ID" --arg tab "$TAB_ID" --arg term "$TERM_ID" --arg cwd "$RESOLVED_CWD" \
  --arg started_at "$NOW_ISO" --arg started_by "$STARTED_BY" --argjson prompt_present "$PROMPT_PRESENT" \
  --arg team "$TEAM" --arg hcom_dir "$HCOM_DIR_REC" --arg hcom_name "$HCOM_NAME" --arg hcom_tag "$HCOM_TAG_REC" \
  '{guid:$guid, short_guid:$short, label:$label, role:$role, agent:$agent,
    extra_args:$extra, argv:$argv, pane_id:$pane, workspace_id:$ws, tab_id:$tab,
    terminal_id:$term, cwd:$cwd, started_at:$started_at, started_by_pane:$started_by,
    initial_prompt_present:$prompt_present,
    team:$team, hcom_dir:$hcom_dir, hcom_name:$hcom_name, hcom_tag:$hcom_tag,
    status:"active"}')"
printf '%s\n' "$RECORD" >>"$REGISTRY"

# Human summary to stderr.
{
  printf 'spawned %s (%s) in pane %s (workspace %s)\n' "$LABEL" "$AGENT" "$PANE_ID" "$WS_ID"
  printf '  guid:   %s\n' "$GUID"
  printf '  cwd:    %s\n' "$RESOLVED_CWD"
  if [[ "$NEW_TAB" -eq 1 ]]; then
    if [[ "$ROOT_CLOSED" -eq 1 ]]; then
      printf '  tab:    %s (new, root shell closed; agent is sole pane)\n' "$TAB"
    else
      printf '  tab:    %s (new; WARNING: root shell NOT closed — spare pane may remain)\n' "$TAB"
    fi
  fi
  if [[ -n "$PERM_INJECTED" ]]; then
    printf '  perms:  %s (autonomous; pass --safe to opt out)\n' "$PERM_INJECTED"
  elif [[ "$SAFE" -eq 1 ]]; then
    printf '  perms:  --safe (agent default ask-mode)\n'
  fi
  if [[ "$NOTIFY" -eq 1 && -n "$NOTIFY_TO" ]]; then
    printf '  notify: rings %s on done (HERDER_SEND + HERDER_NOTIFY_TO injected)\n' "$NOTIFY_TO"
  fi
  if [[ "$IS_HCOM_AGENT" -eq 1 ]]; then
    if [[ "$HCOM_CAPTURE" == "captured" ]]; then
      printf '  bus:    %s @%s  (team: %s)\n' "${TEAM:-global}" "$HCOM_NAME" "${TEAM:-global (~/.hcom)}"
      printf '          HCOM_DIR=%s\n' "$HCOM_DIR_EFF"
    else
      printf '  bus:    %s — name NOT captured (%s); reachable via herdr keystrokes only\n' "${TEAM:-global}" "$HCOM_CAPTURE"
      printf '          HCOM_DIR=%s\n' "$HCOM_DIR_EFF"
    fi
  else
    printf '  bus:    n/a (%s is not an hcom agent; herdr keystroke transport)\n' "$AGENT"
  fi
  if [[ -n "$BRIEF_FILE" ]]; then
    printf '  brief:  staged to %s (codex; sent a one-line pointer to dodge paste-blob/plan-overlay)\n' "$BRIEF_FILE"
  fi
  if [[ -n "$PROMPT" ]]; then
    if $PROMPT_SENT; then
      printf '  prompt: sent (%d chars), ready: %s, verify: %s\n' "${#PROMPT}" "$READY_REASON" "$DELIVERY_RESULT"
    elif [[ "$DELIVERY_RESULT" == "blocked_trust_modal" ]]; then
      printf '  prompt: NOT sent — a directory-trust modal is open and --safe forbids auto-accepting it.\n'
      printf '          Accept it in the pane (focus + Enter), then: herder-send %s "<prompt>"\n' "$LABEL"
    else
      printf '  prompt: NOT confirmed (verify: %s, ready: %s) — read the pane before assuming it landed\n' "$DELIVERY_RESULT" "$READY_REASON"
    fi
  elif [[ "$TRUST_BLOCKED" -eq 1 ]]; then
    printf '  note:   directory-trust modal is open (--safe); accept it in the pane to use the agent\n'
  fi
} >&2

if [[ "$JSON_OUT" -eq 1 ]]; then
  # Enrich the registry record with delivery + permission + capture outcome for the
  # caller. The identity fields (team, hcom_dir, hcom_name, hcom_tag) are already in
  # $RECORD. Conditional keys are merged via `+ (if empty then {} else {...})` rather
  # than `{k:($x|select(.!=""))}`: an empty `select` yields an empty STREAM, which
  # collapses the ENTIRE object to no output (a latent bug in the prior form). The
  # merge form keeps the object.
  printf '%s\n' "$RECORD" | jq -c \
    --argjson sent "$PROMPT_SENT" \
    --arg delivery "$DELIVERY_RESULT" \
    --arg perm "$PERM_INJECTED" \
    --argjson new_tab "$([[ "$NEW_TAB" -eq 1 ]] && echo true || echo false)" \
    --argjson root_closed "$([[ "$ROOT_CLOSED" -eq 1 ]] && echo true || echo false)" \
    --arg brief_file "$BRIEF_FILE" \
    --arg hcom_capture "$HCOM_CAPTURE" \
    '. + {prompt_sent:$sent, delivery_result:$delivery, perm_injected:$perm,
          new_tab:$new_tab, root_pane_closed:$root_closed, hcom_capture:$hcom_capture}
       + (if $brief_file == "" then {} else {brief_file:$brief_file} end)'
fi
