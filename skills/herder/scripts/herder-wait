#!/usr/bin/env bash
# herder-wait — block until a spawned agent reaches a status, optionally read its screen.
#
# Usage:
#   herder-wait <target> [--status idle|working|blocked|done|unknown] [--timeout MS]
#                        [--read] [--lines N] [--source visible|recent|recent-unwrapped]
#
# <target> is one of: short guid, full guid, label, or pane id. A guid/label is
# resolved to the agent's CURRENT pane via its durable terminal_id (registry
# pane_ids go stale as herdr compacts ids); a raw pane id is used verbatim.
# Default status is `idle` (works for the claude/codex integrations, which
# never emit `done`). Pair with the small post-send sleep in herder-spawn so
# the integration has had time to flip to `working` before you wait on idle.
# If the wait returns sooner than expected, read the pane and call again — the
# caller is expected to be smart enough to decide whether to keep waiting.
# Default timeout is 60000ms. Exit code 1 on timeout, matching `herdr wait`.
#
# With --read, prints the pane's recent transcript after the wait returns.

set -euo pipefail

die() { printf 'herder-wait: %s\n' "$*" >&2; exit 1; }
[[ "${HERDR_ENV:-}" = "1" ]] || die "not running inside a herdr pane (HERDR_ENV != 1)"
command -v herdr >/dev/null 2>&1 || die "herdr not on PATH"
command -v jq >/dev/null 2>&1 || die "jq not on PATH"

STATE_DIR="${HERDER_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/herder}"
REGISTRY="$STATE_DIR/registry.jsonl"

STATUS="idle"
TIMEOUT_MS="60000"
DO_READ=0
LINES="30"
SOURCE="recent-unwrapped"
TARGET=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --status) STATUS="$2"; shift 2;;
    --timeout) TIMEOUT_MS="$2"; shift 2;;
    --read) DO_READ=1; shift;;
    --lines) LINES="$2"; shift 2;;
    --source) SOURCE="$2"; shift 2;;
    -h|--help) sed -n '1,14p' "$0"; exit 0;;
    --*) die "unknown flag: $1";;
    *) [[ -z "$TARGET" ]] || die "extra positional arg: $1"; TARGET="$1"; shift;;
  esac
done

[[ -n "$TARGET" ]] || die "target required (guid, label, or pane id)"

# Resolve target → LIVE pane_id (drift-proof). The registry pane_id is captured at
# spawn and goes stale as herdr compacts pane_ids; terminal_id is the durable
# identity, so re-resolve a guid/label to where its terminal lives now. A raw
# pane_id is used verbatim. Same resolution as herder-send / herder-cull.
PANE_LIST_JSON="$(herdr pane list 2>/dev/null || true)"
resolve_pane() {
  local v="$1" rec term stored live npanes
  if [[ -f "$REGISTRY" ]]; then
    rec="$(jq -sc --arg v "$v" '
      group_by(.guid) | map(.[-1])
      | map(select(.guid==$v or .short_guid==$v or .label==$v))
      | last // empty' "$REGISTRY")"
  fi
  if [[ -z "${rec:-}" ]]; then printf '%s' "$v"; return 0; fi
  term="$(printf '%s' "$rec" | jq -r '.terminal_id // empty')"
  stored="$(printf '%s' "$rec" | jq -r '.pane_id // empty')"
  if [[ -z "$term" ]]; then printf '%s' "$stored"; return 0; fi
  live="$(printf '%s' "$PANE_LIST_JSON" | jq -r --arg t "$term" \
    '.result.panes[]? | select(.terminal_id==$t) | .pane_id' 2>/dev/null | head -n1)"
  if [[ -n "$live" ]]; then printf '%s' "$live"; return 0; fi
  npanes="$(printf '%s' "$PANE_LIST_JSON" | jq '[.result.panes[]?] | length' 2>/dev/null || echo 0)"
  if [[ "${npanes:-0}" -eq 0 ]]; then
    printf 'herder-wait: could not read live pane list; cannot resolve %s\n' "$v" >&2
  else
    printf 'herder-wait: %s (terminal %s) is not live anywhere — agent gone or culled\n' "$v" "$term" >&2
  fi
  return 1
}
set +e
PANE_ID="$(resolve_pane "$TARGET")"
RESOLVE_RC=$?
set -e
[[ $RESOLVE_RC -eq 0 ]] || exit 1
[[ -n "$PANE_ID" ]] || PANE_ID="$TARGET"

set +e
herdr wait agent-status "$PANE_ID" --status "$STATUS" --timeout "$TIMEOUT_MS" >/dev/null 2>&1
WAIT_RC=$?
set -e

if [[ $WAIT_RC -ne 0 ]]; then
  printf 'herder-wait: timeout waiting for %s to reach status=%s\n' "$PANE_ID" "$STATUS" >&2
fi

if [[ "$DO_READ" -eq 1 ]]; then
  herdr pane read "$PANE_ID" --source "$SOURCE" --lines "$LINES"
fi

exit $WAIT_RC
