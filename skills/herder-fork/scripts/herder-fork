#!/usr/bin/env bash
# herder-fork — fork the current claude/codex session into a new herdr pane.
#
# Usage:
#   herder-fork [--right|--below] [--agent claude|codex] [--session-id UUID]
#               [--cwd PATH] [--skip-perms|--yolo]
#               [--prompt TEXT] [--focus] [-- EXTRA_AGENT_ARGS...]
#
# Registered Claude sessions use `bin/herder fork <guid>` so the child is
# bus-bound from birth and carries provenance.forked_from. Codex self-fork and
# unregistered Claude sessions fall back to raw tool fork/resume through
# `herder-spawn`.

set -euo pipefail

die() { printf 'herder-fork: %s\n' "$*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

script_realpath() {
  python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0" 2>/dev/null ||
    readlink -f "$0" 2>/dev/null ||
    printf '%s\n' "$0"
}

repo_root_from_self() {
  local self
  self="$(script_realpath)"
  dirname "$(dirname "$(dirname "$self")")"
}

resolve_herder_bin() {
  local repo
  repo="$(repo_root_from_self)"
  if [[ -x "$repo/bin/herder" ]]; then
    printf '%s\n' "$repo/bin/herder"
    return
  fi
  if have herder; then
    printf 'herder'
    return
  fi
  die "bin/herder not found at $repo/bin/herder or on PATH"
}

resolve_herder_spawn() {
  if have herder-spawn; then
    printf 'herder-spawn'
    return
  fi

  local self skills_dir sibling
  self="$(script_realpath)"
  skills_dir="$(dirname "$(dirname "$(dirname "$self")")")"
  sibling="$skills_dir/herder/scripts/herder-spawn"
  [[ -x "$sibling" ]] || die "herder-spawn not found on PATH or at $sibling"
  printf '%s\n' "$sibling"
}

registry_path() {
  if [[ -n "${HERDER_STATE_DIR:-}" ]]; then
    printf '%s\n' "$HERDER_STATE_DIR/registry.jsonl"
  elif [[ -n "${XDG_STATE_HOME:-}" ]]; then
    printf '%s\n' "$XDG_STATE_HOME/herder/registry.jsonl"
  else
    printf '%s\n' "$HOME/.local/state/herder/registry.jsonl"
  fi
}

[[ "${HERDR_ENV:-}" = "1" ]] || die "not running inside a herdr pane (HERDR_ENV != 1)"
[[ -n "${HERDR_PANE_ID:-}" ]] || die "HERDR_PANE_ID not set; cannot anchor fork to current pane"
HERDER_BIN="$(resolve_herder_bin)"

SPLIT="right"
AGENT=""
SESSION_ID=""
PROMPT=""
FOCUS_FLAG="--no-focus"
CWD=""
SKIP_PERMS=0
PASSTHROUGH=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --right) SPLIT="right"; shift ;;
    --below|--down) SPLIT="down"; shift ;;
    --agent) AGENT="${2:-}"; [[ -n "$AGENT" ]] || die "--agent requires a value"; shift 2 ;;
    --session-id) SESSION_ID="${2:-}"; [[ -n "$SESSION_ID" ]] || die "--session-id requires a value"; shift 2 ;;
    --prompt) PROMPT="${2:-}"; [[ -n "$PROMPT" ]] || die "--prompt requires a value"; shift 2 ;;
    --cwd) CWD="${2:-}"; [[ -n "$CWD" ]] || die "--cwd requires a value"; shift 2 ;;
    --skip-perms|--yolo) SKIP_PERMS=1; shift ;;
    --focus) FOCUS_FLAG="--focus"; shift ;;
    --no-focus) FOCUS_FLAG="--no-focus"; shift ;;
    --) shift; PASSTHROUGH+=("$@"); break ;;
    -h|--help) sed -n '1,14p' "$0"; exit 0 ;;
    *) die "unknown arg: $1" ;;
  esac
done

PANE_JSON="$(herdr pane get "$HERDR_PANE_ID" 2>&1 || true)"
PANE_ID="$(printf '%s' "$PANE_JSON" | jq -r '.result.pane.pane_id // empty' 2>/dev/null || true)"
WORKSPACE_ID="$(printf '%s' "$PANE_JSON" | jq -r '.result.pane.workspace_id // empty' 2>/dev/null || true)"

if [[ -z "$AGENT" ]]; then
  if [[ "${CLAUDECODE:-0}" = "1" || -n "${CLAUDE_CODE_SESSION_ID:-}" ]]; then
    AGENT="claude"
  elif [[ "${AI_AGENT:-}" == claude-code* ]]; then
    AGENT="claude"
  elif [[ -n "${CODEX_HOME:-}" ]]; then
    AGENT="codex"
  else
    die "could not detect agent; pass --agent claude|codex"
  fi
fi

if [[ -z "$CWD" ]]; then
  CWD="$(printf '%s' "$PANE_JSON" | jq -r '.result.pane.foreground_cwd // .result.pane.cwd // empty' 2>/dev/null || true)"
  if [[ -z "$CWD" && -n "$WORKSPACE_ID" ]]; then
    WS_LIST_JSON="$(herdr workspace list 2>&1 || true)"
    CWD="$(printf '%s' "$WS_LIST_JSON" | jq -r --arg ws "$WORKSPACE_ID" '
      .result.workspaces[]? | select(.workspace_id==$ws)
      | (.worktree.checkout_path // .worktree.repo_root // .cwd // empty)
    ' 2>/dev/null || true)"
  fi
  [[ -n "$CWD" ]] || CWD="$PWD"
fi

current_hcom_identity() {
  [[ -n "$PANE_ID" ]] || return 0
  have hcom || return 0
  hcom list --json 2>/dev/null | jq -r --arg pane "$PANE_ID" '
    .[]? | select((.launch_context.pane_id // "") == $pane)
    | [(.name // ""), (.session_id // "")] | @tsv
  ' 2>/dev/null | tail -n1
}

registered_guid_for_current_session() {
  if [[ -n "${HERDER_GUID:-}" ]]; then
    printf '%s\n' "$HERDER_GUID"
    return
  fi

  local hcom_name="" hcom_session="" identity reg
  identity="$(current_hcom_identity || true)"
  if [[ -n "$identity" ]]; then
    hcom_name="${identity%%$'\t'*}"
    hcom_session="${identity#*$'\t'}"
    [[ "$identity" == *$'\t'* ]] || hcom_session=""
  fi
  [[ -n "$SESSION_ID" ]] || SESSION_ID="${CLAUDE_CODE_SESSION_ID:-$hcom_session}"

  reg="$(registry_path)"
  [[ -f "$reg" ]] || return 0
  jq -sr --arg hcom_name "$hcom_name" --arg session "$SESSION_ID" '
    def key: (.guid // "");
    sort_by(key)
    | group_by(key)
    | map(.[-1])
    | map(select(
        (($hcom_name != "") and ((.hcom_name // "") == $hcom_name)) or
        (($session != "") and ((.provenance.tool_session_id // "") == $session))
      ))
    | last.guid // empty
  ' "$reg" 2>/dev/null || true
}

if [[ "$AGENT" = "claude" ]]; then
  native_target="$(registered_guid_for_current_session)"
  if [[ -n "$native_target" ]]; then
    fork_args=(fork "$native_target")
    [[ -z "$PROMPT" ]] || fork_args+=(--prompt "$PROMPT")
    HERDER_LIFECYCLE_CWD="$CWD" \
      HERDER_LIFECYCLE_SPLIT="$SPLIT" \
      HERDER_LIFECYCLE_FOCUS="$FOCUS_FLAG" \
      exec "$HERDER_BIN" "${fork_args[@]}"
  fi
fi

agent_args=()
case "$AGENT" in
  claude)
    [[ -n "$SESSION_ID" ]] || SESSION_ID="${CLAUDE_CODE_SESSION_ID:-}"
    [[ -n "$SESSION_ID" ]] || die "no registered herder guid or claude session id (set --session-id, run inside claude, or herder-enroll first)"
    agent_args=(--resume "$SESSION_ID" --fork-session)
    [[ -n "${CLAUDE_EFFORT:-}" ]] && agent_args+=(--effort "$CLAUDE_EFFORT")
    [[ "$SKIP_PERMS" -eq 1 ]] && agent_args+=(--dangerously-skip-permissions)
    ;;
  codex)
    if [[ -n "$SESSION_ID" ]]; then
      agent_args=(fork "$SESSION_ID")
    else
      agent_args=(fork --last)
    fi
    [[ "$SKIP_PERMS" -eq 1 ]] &&
      printf 'herder-fork: --skip-perms is claude-only; ignoring for codex\n' >&2
    ;;
  *) die "unknown agent: $AGENT (use claude or codex)" ;;
esac

[[ "${#PASSTHROUGH[@]}" -eq 0 ]] || agent_args+=("${PASSTHROUGH[@]}")

HERDER_SPAWN="$(resolve_herder_spawn)"
spawn_args=(
  --role "fork-${AGENT}"
  --agent "$AGENT"
  --from-pane "$HERDR_PANE_ID"
  --cwd "$CWD"
  --split "$SPLIT"
  "$FOCUS_FLAG"
)

for arg in "${agent_args[@]}"; do
  spawn_args+=(--extra-arg "$arg")
done

[[ -z "$PROMPT" ]] || spawn_args+=(--prompt "$PROMPT")

exec "$HERDER_SPAWN" "${spawn_args[@]}"
