#!/usr/bin/env bash
# herder-fork — fork the current claude/codex session into a new herdr pane.
#
# Usage:
#   herder-fork [--right|--below] [--agent claude|codex] [--session-id UUID]
#               [--cwd PATH] [--skip-perms|--yolo]
#               [--prompt TEXT] [--focus] [-- EXTRA_AGENT_ARGS...]
#
# Detects the running agent from env (CLAUDECODE / CLAUDE_CODE_SESSION_ID / CODEX_HOME)
# or Herdr's pane metadata, then calls `herder-spawn` to launch a forked session
# next to the current pane.
#
# Auto-resolves the forked pane's cwd from the current pane's foreground_cwd/cwd,
# then falls back to the workspace checkout path, so `claude --resume` finds the
# original session (Claude Code stores sessions per-project-directory; spawning
# in the wrong cwd causes the resume to fail and the pane to die within seconds).
# Override with --cwd if you really need to.
#
# For claude: invokes `claude --resume <id> --fork-session` (propagates $CLAUDE_EFFORT).
#             --skip-perms (alias --yolo) appends --dangerously-skip-permissions.
# For codex : invokes `codex fork <id>` or `codex fork --last`.
#
# Any args after `--` are appended AFTER --resume/--fork-session, so they reach the
# forked agent unchanged (e.g. `-- --model claude-sonnet-4-6`).

set -euo pipefail

die() { printf 'herder-fork: %s\n' "$*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

# Resolve herder-spawn: prefer $PATH, else fall back to the sibling skill's
# script via this script's real location (resilient to being run through a
# symlink in $HOME/.claude/skills/, $HOME/.codex/skills/, etc).
resolve_herder_spawn() {
  if have herder-spawn; then
    printf 'herder-spawn'
    return
  fi

  local self
  self="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || printf '%s' "$0")"
  local skills_dir
  skills_dir="$(dirname "$(dirname "$(dirname "$self")")")"
  local sibling="$skills_dir/herder/scripts/herder-spawn"
  [[ -x "$sibling" ]] || die "herder-spawn not found on PATH or at $sibling"
  printf '%s' "$sibling"
}

[[ "${HERDR_ENV:-}" = "1" ]] || die "not running inside a herdr pane (HERDR_ENV != 1)"
have herdr || die "herdr not on PATH"
have jq || die "jq not on PATH"
HERDER_SPAWN="$(resolve_herder_spawn)"
[[ -n "${HERDR_PANE_ID:-}" ]] || die "HERDR_PANE_ID not set; cannot anchor fork to current pane"

SELF_PANE_JSON="$(herdr pane get "$HERDR_PANE_ID" 2>/dev/null || true)"

reported_self_agent() {
  printf '%s' "$SELF_PANE_JSON" | jq -r '.result.pane.agent // empty' 2>/dev/null || true
}

reported_session_id_for() {
  local want_agent="$1"
  printf '%s' "$SELF_PANE_JSON" | jq -r --arg want "$want_agent" '
    .result.pane.agent_session as $session
    | if ($session != null and (($session.agent // "") == $want)) then
        ($session.value // "")
      else
        ""
      end
  ' 2>/dev/null || true
}

SPLIT="right"
AGENT=""
SESSION_ID=""
PROMPT=""
FOCUS_FLAG="--no-focus"
CWD=""
SKIP_PERMS=0
PASSTHROUGH=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --right) SPLIT="right"; shift;;
    --below|--down) SPLIT="down"; shift;;
    --agent) AGENT="$2"; shift 2;;
    --session-id) SESSION_ID="$2"; shift 2;;
    --prompt) PROMPT="$2"; shift 2;;
    --cwd) CWD="$2"; shift 2;;
    --skip-perms|--yolo) SKIP_PERMS=1; shift;;
    --focus) FOCUS_FLAG="--focus"; shift;;
    --no-focus) FOCUS_FLAG="--no-focus"; shift;;
    --) shift; PASSTHROUGH+=("$@"); break;;
    -h|--help) sed -n '1,22p' "$0"; exit 0;;
    *) die "unknown arg: $1";;
  esac
done

if [[ -z "$AGENT" ]]; then
  if [[ "${CLAUDECODE:-0}" = "1" || -n "${CLAUDE_CODE_SESSION_ID:-}" ]]; then
    AGENT="claude"
  elif [[ "${AI_AGENT:-}" == claude-code* ]]; then
    AGENT="claude"
  elif [[ -n "${CODEX_HOME:-}" ]]; then
    AGENT="codex"
  elif [[ "$(reported_self_agent)" =~ ^(claude|codex)$ ]]; then
    AGENT="$(reported_self_agent)"
  else
    die "could not detect agent; pass --agent claude|codex"
  fi
fi

agent_args=()
case "$AGENT" in
  claude)
    [[ -n "$SESSION_ID" ]] || SESSION_ID="${CLAUDE_CODE_SESSION_ID:-}"
    [[ -n "$SESSION_ID" ]] || SESSION_ID="$(reported_session_id_for claude)"
    [[ -n "$SESSION_ID" ]] || die "no claude session id (set --session-id or run inside a claude session)"
    agent_args=(--resume "$SESSION_ID" --fork-session)
    [[ -n "${CLAUDE_EFFORT:-}" ]] && agent_args+=(--effort "$CLAUDE_EFFORT")
    [[ "$SKIP_PERMS" -eq 1 ]] && agent_args+=(--dangerously-skip-permissions)
    ;;
  codex)
    [[ -n "$SESSION_ID" ]] || SESSION_ID="$(reported_session_id_for codex)"
    if [[ -n "$SESSION_ID" ]]; then
      agent_args=(fork "$SESSION_ID")
    else
      agent_args=(fork --last)
    fi
    [[ "$SKIP_PERMS" -eq 1 ]] && \
      printf 'herder-fork: --skip-perms is claude-only; ignoring for codex\n' >&2
    ;;
  *) die "unknown agent: $AGENT (use claude or codex)";;
esac

# PASSTHROUGH lands AFTER --resume/--fork-session so user-supplied flags
# reach claude/codex unchanged (e.g. -- --model claude-sonnet-4-6).
[[ "${#PASSTHROUGH[@]}" -eq 0 ]] || agent_args+=("${PASSTHROUGH[@]}")

# Resolve the cwd of the current pane. Claude Code stores
# sessions per project directory, so `claude --resume <id> --fork-session`
# launched in the wrong cwd silently finds no matching session and exits
# within seconds — the forked pane dies. We anchor the new pane to the
# original session's project root from Herdr pane metadata first, then the
# workspace's worktree path.
if [[ -z "$CWD" ]]; then
  FROM_PANE_JSON="$SELF_PANE_JSON"
  CWD="$(printf '%s' "$FROM_PANE_JSON" | jq -r '
    .result.pane.foreground_cwd // .result.pane.cwd // empty
  ' 2>/dev/null || true)"
  WS_ID="$(printf '%s' "$FROM_PANE_JSON" | jq -r '.result.pane.workspace_id // empty' 2>/dev/null || true)"
  if [[ -z "$CWD" && -n "$WS_ID" ]]; then
    WS_LIST_JSON="$(herdr workspace list 2>&1 || true)"
    CWD="$(printf '%s' "$WS_LIST_JSON" | jq -r --arg ws "$WS_ID" '
      .result.workspaces[]? | select(.workspace_id==$ws)
      | (.worktree.checkout_path // .worktree.repo_root // .cwd // empty)
    ' 2>/dev/null || true)"
  fi
  # Last-resort fallback: current pwd. Better than letting herder-spawn
  # default to whichever workspace happened to be created first.
  [[ -n "$CWD" ]] || CWD="$PWD"
fi

spawn_args=(
  --role "fork-${AGENT}"
  --agent "$AGENT"
  --from-pane "$HERDR_PANE_ID"
  --cwd "$CWD"
  --split "$SPLIT"
  "$FOCUS_FLAG"
)

for arg in "${agent_args[@]}"; do
  spawn_args+=(--extra-arg "$arg")
done

[[ -z "$PROMPT" ]] || spawn_args+=(--prompt "$PROMPT")

exec "$HERDER_SPAWN" "${spawn_args[@]}"
