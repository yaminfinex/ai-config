# sesh — local builds and user-owned installs are independent copies.

# --- store host (quick-host VM; override via env) ---
project := env_var_or_default("SESH_GCP_PROJECT", "prod-infinex-687a")
zone    := env_var_or_default("SESH_GCP_ZONE", "northamerica-south1-c")
vm      := env_var_or_default("SESH_STORE_VM", "quick-host")
release_dest := env_var_or_default("SESH_RELEASE_DEST", "sesh-host:/var/lib/sesh/releases")

# canonical version: git-describe against the monorepo-prefixed release tags
# (`just tag` creates sesh-vX.Y.Z; other repo tags are ignored), falling back
# to the bare commit hash before the first tag exists
version := `git describe --tags --match 'sesh-v*' --always --dirty`
ldflags := "-s -w -X sesh/internal/buildinfo.Version=" + version
gobin := `bin="$(go env GOBIN)"; if [ -z "$bin" ]; then bin="$(go env GOPATH)/bin"; fi; printf '%s' "$bin"`

_default:
    @just --list

build:
    go build -ldflags '{{ldflags}}' -o sesh ./cmd/sesh
    @echo "built ./sesh  ({{version}})"

# The full store-side binary (client commands + serve/reindex/admin, tsnet,
# sqlite). Never published to the release channel; deploy-store ships it.
build-store:
    go build -ldflags '{{ldflags}}' -o sesh-store ./cmd/sesh-store
    @echo "built ./sesh-store  ({{version}})"

run *args: build
    ./sesh {{args}}

test:
    go test ./...

# Owner-run portability check. This is intentionally manual: the project has
# no macOS CI runner, and a laptop cron would produce unactionable noise.
test-darwin:
    @test "$(uname -s)" = Darwin || { echo "test-darwin must run on macOS" >&2; exit 2; }
    go test ./...
    go test -race ./internal/update ./internal/ship
    go test ./internal/ship -run '^TestPeriodicWatchRewalkRegistersNestedDirectory$' -count=200

install:
    go install -ldflags '{{ldflags}}' ./cmd/sesh
    @echo "installed sesh  ({{version}})  ->  {{gobin}}/sesh"

# Install the current binary and (re)configure the per-user shipper.
# Delegates to `sesh setup` so the repo path and field onboarding (curl
# install.sh) exercise identical code. --force is only needed when the
# node-local config was operator-edited (broken/absent provenance digest).
deploy store_url *args: install
    {{gobin}}/sesh setup --store-url {{store_url}} {{args}}

# Tag a release: `just tag 0.1.0` creates the monorepo-prefixed tag
# sesh-v0.1.0 on the current commit. Push is manual.
tag semver:
    @case '{{semver}}' in [0-9]*.[0-9]*.[0-9]*) ;; *) echo "usage: just tag X.Y.Z (numeric, no leading v — the tag becomes sesh-vX.Y.Z)" >&2; exit 2 ;; esac
    git tag 'sesh-v{{semver}}'
    @echo "tagged sesh-v{{semver}} — push with: git push origin sesh-v{{semver}}"

# Publish a release to the store's channel (design §7, two-verb discipline:
# publishing artifacts ≠ deploying the store). Matrix build, remote staging,
# checksum verify, atomic promote (republish refused), durable latest flip.
# Default dest is the quick-host deployment; `sesh-host` is an ssh alias
# (ops/README.md shows the IAP ProxyCommand config and group membership).
release dest=release_dest:
    scripts/release.sh {{dest}}

# Upgrade the LIVE store on the VM (publish ≠ deploy: `just release` ships
# artifacts to the channel; this restarts prod). quick's deploy-server shape:
# static linux/amd64 build, gcloud IAP scp, then ops/deploy-remote.sh swaps
# the binary crash-safely (sesh.prev retained via hardlink, atomic rename —
# the only known-good binary is never overwritten in place), restarts
# sesh-serve, and prints the version of the RUNNING image.
deploy-store:
    CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -ldflags '{{ldflags}}' -o /tmp/sesh-linux-amd64 ./cmd/sesh-store
    gcloud compute scp --tunnel-through-iap --zone {{zone}} --project {{project}} /tmp/sesh-linux-amd64 ops/deploy-remote.sh {{vm}}:/tmp/
    gcloud compute ssh {{vm}} --tunnel-through-iap --zone {{zone}} --project {{project}} --command 'sudo sh /tmp/deploy-remote.sh /tmp/sesh-linux-amd64'

# Restart an already configured service after installing the current binary.
restart: install
    @case "$(uname -s)" in Linux) systemctl --user restart sesh-ship.service ;; Darwin) launchctl kickstart -k "gui/$(id -u)/dev.sesh.ship" ;; *) echo "unsupported platform" >&2; exit 2 ;; esac

# Compare this checkout with the shipper without requiring it to run. Linux
# reads the running image; macOS can only inspect the executable path on disk,
# which may differ from the running image until the service restarts.
versions:
    @echo "local    {{version}}"
    @if [ "$(uname -s)" = Linux ]; then pid="$(systemctl --user show sesh-ship.service --property=MainPID --value 2>/dev/null || true)"; if [ -n "$pid" ] && [ "$pid" != 0 ] && [ -x "/proc/$pid/exe" ]; then printf 'running  '; "/proc/$pid/exe" version; else echo "running  (not running)"; fi; else label="gui/$(id -u)/dev.sesh.ship"; pid="$(launchctl print "$label" 2>/dev/null | awk '/pid =/{print $3; exit}')"; if [ -n "$pid" ]; then executable="$(ps -p "$pid" -o comm=)"; printf 'on-disk  '; "$executable" version; else echo "on-disk  (not running)"; fi; fi

clean:
    rm -f sesh sesh-store
