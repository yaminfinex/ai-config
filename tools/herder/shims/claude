#!/usr/bin/env bash
# herder-path-shim: claude — sibling herder shims detect this marker line and skip it.
#
# claude shim - daily entry point for hcom-bound launches.
#
# Normal path: claude [args...] -> bin/herder launch claude [default args] [args...].
# Recursion path: herder launch exports HCOM_LAUNCH_INFLIGHT=1 before `hcom claude`; if
# hcom resolves `claude` through PATH and lands back here, this shim skips itself (and
# any sibling herder shim from another checkout, by marker) and execs the real binary.
# HERDER_SHIM_ARGS_CLAUDE is deliberately whitespace-split and prepended before user
# args, so today's alias default can move to mise [env] instead of being hardcoded here.

set -euo pipefail

TOOL="claude"
DEFAULT_ARGS_VAR="HERDER_SHIM_ARGS_CLAUDE"

die() { printf '%s shim: %s\n' "$TOOL" "$*" >&2; exit 1; }

canonical_path() {
  local path="$1" dir base
  case "$path" in
    */*) ;;
    *) path="$(command -v -- "$path" 2>/dev/null || true)" ;;
  esac
  [[ -n "$path" ]] || return 1
  dir="$(dirname "$path")"
  base="$(basename "$path")"
  [[ "$dir" = /* ]] || dir="$PWD/$dir"
  dir="$(cd "$dir" 2>/dev/null && pwd -P)" || return 1
  printf '%s/%s\n' "$dir" "$base"
}

shim_path="$(canonical_path "${BASH_SOURCE[0]}")" || die "cannot resolve shim path"
shim_dir="$(dirname "$shim_path")"
repo_root="$(cd "$shim_dir/../../.." 2>/dev/null && pwd -P)" || die "cannot resolve repo root"
herder_launch="$repo_root/bin/herder"

# A candidate is a herder shim (this file or a sibling copy from another
# checkout/worktree) iff its head carries the marker line. Content beats path
# comparison: two shim dirs on one PATH must never exec each other and loop.
is_herder_shim() {
  LC_ALL=C head -c 512 -- "$1" 2>/dev/null | grep -Fq 'herder-path-shim'
}

find_real_tool() {
  local entry candidate
  IFS=:
  for entry in $PATH; do
    [[ -n "$entry" ]] || entry="."
    candidate="$entry/$TOOL"
    [[ -x "$candidate" && ! -d "$candidate" ]] || continue
    candidate="$(canonical_path "$candidate" 2>/dev/null || true)"
    [[ -n "$candidate" ]] || continue
    [[ "$candidate" == "$shim_path" ]] && continue
    is_herder_shim "$candidate" && continue
    printf '%s\n' "$candidate"
    return 0
  done
  return 1
}

if [[ "${HCOM_LAUNCH_INFLIGHT:-}" == "1" ]]; then
  real_tool="$(find_real_tool)" || die "HCOM_LAUNCH_INFLIGHT=1 but no real '$TOOL' binary found on PATH"
  exec "$real_tool" "$@"
fi

[[ -x "$herder_launch" && ! -d "$herder_launch" ]] || \
  die "missing executable bin/herder at $herder_launch"

export HERDER_SHIM=1
default_args="${!DEFAULT_ARGS_VAR:-}"
if [[ -n "$default_args" ]]; then
  # Intentional whitespace splitting: HERDER_SHIM_ARGS_CLAUDE is a simple mise/env default string.
  exec "$herder_launch" launch "$TOOL" $default_args "$@"
else
  exec "$herder_launch" launch "$TOOL" "$@"
fi
