#!/usr/bin/env bash
# codex shim - daily entry point for hcom-bound launches.
#
# Normal path: codex [args...] -> bin/herder launch codex [default args] [args...].
# Recursion path: herder launch exports HCOM_LAUNCH_INFLIGHT=1 before `hcom codex`; if
# hcom resolves `codex` through PATH and lands back here, this shim skips itself and
# execs the real binary. HERDER_SHIM_ARGS_CODEX is deliberately whitespace-split and
# prepended before user args, so static defaults can live in mise [env] instead of
# being hardcoded here.

set -euo pipefail

TOOL="codex"
DEFAULT_ARGS_VAR="HERDER_SHIM_ARGS_CODEX"

die() { printf '%s shim: %s\n' "$TOOL" "$*" >&2; exit 1; }

canonical_path() {
  local path="$1" dir base
  case "$path" in
    */*) ;;
    *) path="$(command -v -- "$path" 2>/dev/null || true)" ;;
  esac
  [[ -n "$path" ]] || return 1
  dir="$(dirname "$path")"
  base="$(basename "$path")"
  [[ "$dir" = /* ]] || dir="$PWD/$dir"
  dir="$(cd "$dir" 2>/dev/null && pwd -P)" || return 1
  printf '%s/%s\n' "$dir" "$base"
}

shim_path="$(canonical_path "${BASH_SOURCE[0]}")" || die "cannot resolve shim path"
shim_dir="$(dirname "$shim_path")"
repo_root="$(cd "$shim_dir/../../.." 2>/dev/null && pwd -P)" || die "cannot resolve repo root"
herder_launch="$repo_root/bin/herder"

find_real_tool() {
  local entry candidate
  IFS=:
  for entry in $PATH; do
    [[ -n "$entry" ]] || entry="."
    candidate="$entry/$TOOL"
    [[ -x "$candidate" && ! -d "$candidate" ]] || continue
    candidate="$(canonical_path "$candidate" 2>/dev/null || true)"
    [[ -n "$candidate" ]] || continue
    [[ "$candidate" == "$shim_path" ]] && continue
    printf '%s\n' "$candidate"
    return 0
  done
  return 1
}

if [[ "${HCOM_LAUNCH_INFLIGHT:-}" == "1" ]]; then
  real_tool="$(find_real_tool)" || die "HCOM_LAUNCH_INFLIGHT=1 but no real '$TOOL' binary found on PATH"
  exec "$real_tool" "$@"
fi

[[ -x "$herder_launch" && ! -d "$herder_launch" ]] || \
  die "missing executable bin/herder at $herder_launch"

export HERDER_SHIM=1
default_args="${!DEFAULT_ARGS_VAR:-}"
if [[ -n "$default_args" ]]; then
  # Intentional whitespace splitting: HERDER_SHIM_ARGS_CODEX is a simple mise/env default string.
  exec "$herder_launch" launch "$TOOL" $default_args "$@"
else
  exec "$herder_launch" launch "$TOOL" "$@"
fi
