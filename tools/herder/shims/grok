#!/usr/bin/env bash
# herder-path-shim: grok — sibling herder shims detect this marker line and skip it.
#
# grok shim - daily entry point for the first-class Grok family.
#
# The explicit GROK=/absolute/vendor/binary escape hatch bypasses herder. With
# no override, this enters the herder launch contract, which skips this shim
# and resolves the next vendor executable using normal PATH order.

set -euo pipefail

TOOL="grok"

die() { printf '%s shim: %s\n' "$TOOL" "$*" >&2; exit 1; }

canonical_path() {
  local path="$1" dir base
  case "$path" in
    */*) ;;
    *) path="$(command -v -- "$path" 2>/dev/null || true)" ;;
  esac
  [[ -n "$path" ]] || return 1
  dir="$(dirname "$path")"
  base="$(basename "$path")"
  [[ "$dir" = /* ]] || dir="$PWD/$dir"
  dir="$(cd "$dir" 2>/dev/null && pwd -P)" || return 1
  printf '%s/%s\n' "$dir" "$base"
}

shim_path="$(canonical_path "${BASH_SOURCE[0]}")" || die "cannot resolve shim path"
shim_dir="$(dirname "$shim_path")"
repo_root="$(cd "$shim_dir/../../.." 2>/dev/null && pwd -P)" || die "cannot resolve repo root"
herder_launch="$repo_root/bin/herder"

is_herder_shim() {
  LC_ALL=C head -c 512 -- "$1" 2>/dev/null | grep -Fq 'herder-path-shim'
}

if [[ -n "${GROK:-}" ]]; then
  case "$GROK" in
    /*) ;;
    *) die "GROK vendor bypass must be an absolute executable path (got: $GROK)" ;;
  esac
  vendor="$(canonical_path "$GROK" 2>/dev/null || true)"
  [[ -n "$vendor" && -x "$vendor" && ! -d "$vendor" ]] || \
    die "GROK vendor bypass is not an executable file: $GROK"
  ! is_herder_shim "$vendor" || die "GROK vendor bypass points to a herder shim, not a vendor binary"
  exec "$vendor" "$@"
fi

[[ -x "$herder_launch" && ! -d "$herder_launch" ]] || \
  die "missing executable bin/herder at $herder_launch"

export HERDER_SHIM=1
exec "$herder_launch" launch "$TOOL" "$@"
