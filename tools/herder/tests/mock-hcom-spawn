#!/usr/bin/env bash
# mock-hcom-spawn — a deterministic, hermetic stand-in for the `hcom` CLI, used
# by check-spawn-contract.sh to exercise herder spawn's hcom NAME CAPTURE
# (correlating the child's frozen launch pane_id to the bus entry) AND the
# bus-first initial-prompt delivery (TASK-032: bind-wait → `hcom send` → the
# receipt poll) without a live bus. It answers:
#   hcom list --json                                       → bus roster (capture)
#   hcom list <bus_name>                                   → joined? (send precheck)
#   hcom send --from <sender> @<bus_name> -- <message>     → deliver (exit 0/1)
#   hcom events --last N --agent <name> --context deliver:<sender> --after <iso>
#                                                          → receipt array
# It also satisfies `command -v hcom` (hcom is a hard dependency for
# hcom-capable agents).
#
# Behaviour is driven by env vars (set by the harness):
#   MOCK_HCOM_SPAWN_SCENARIO   <capture>[_<delivery>]
#     capture half:
#       launchctx (default) — an entry whose launch_context.pane_id is p_50
#                             (the frozen launch pane) exists → primary capture
#       fallback            — no launch_context match; a UNIQUE entry with the
#                             spawn tag ("worker") and directory /mock/cwd exists
#                             (decoys differ in tag/dir). TASK-033: tag+cwd is no
#                             longer a capture signal, so this stale unique match
#                             is NOT captured → not_found (row left empty)
#       fallback_ambiguous  — no launch_context match; TWO live entries share
#                             tag ("worker") + directory /mock/cwd → no positive
#                             correlate → not captured → not_found (row left empty)
#       fail                — empty bus → capture fails (promptless spawn stays
#                             best-effort; a bus prompt reports bind_timeout)
#     delivery half (bus prompts only; default = receipt on first poll):
#       *_queued            — send succeeds, no receipt ever → verify: queued
#       *_sendfail          — `hcom send` exits 1 → verify: send_failed
#   MOCK_PROBE_DIR   probe dir; every invocation records the effective
#                    HCOM_DIR to hcom_dir (proves capture AND delivery are
#                    scoped to the global bus); send/events argv are
#                    recorded to send_argv/events_argv for the goldens

set -euo pipefail

SCEN="${MOCK_HCOM_SPAWN_SCENARIO:-launchctx}"
PROBE="${MOCK_PROBE_DIR:?}"
mkdir -p "$PROBE"

printf '%s' "${HCOM_DIR:-<unset>}" >"$PROBE/hcom_dir"

case "${1:-} ${2:-}" in
  "list --json")
    case "$SCEN" in
      launchctx*)
        jq -n --arg sender "${MOCK_SPAWNER_BUS:-dispatcher-rive}" '[
          {name:$sender, joined:true, session_id:"current-session",
           created_at:"2026-01-01T00:00:00Z", launch_context:{pane_id:"p_orch"}},
          {name:"decoy-yolo",  tag:"other",  directory:"/elsewhere",
           created_at:"2026-01-01T00:00:00Z", launch_context:{pane_id:"p_99"}},
          {name:"worker-rive", tag:"worker", directory:"/elsewhere",
           created_at:"2026-01-01T00:00:01Z", launch_context:{pane_id:"p_50"}}
        ]';;
      emptyctx)
        jq -n --arg sender "${MOCK_SPAWNER_BUS:-dispatcher-rive}" '[
          {name:$sender, joined:true, session_id:"", created_at:"2026-01-01T00:00:00Z", launch_context:{}},
          {name:"worker-rive", tag:"worker", directory:"/elsewhere",
           created_at:"2026-01-01T00:00:01Z", launch_context:{pane_id:"p_50"}}
        ]';;
      emptyctx_duplicate)
        jq -n --arg sender "${MOCK_SPAWNER_BUS:-dispatcher-rive}" '[
          {name:$sender, joined:true, session_id:"", created_at:"2026-01-01T00:00:00Z", launch_context:{}},
          {name:$sender, joined:true, session_id:"", created_at:"2026-01-01T00:00:01Z", launch_context:{}}
        ]';;
      wrongctx)
        jq -n --arg sender "${MOCK_SPAWNER_BUS:-dispatcher-rive}" '[
          {name:$sender, joined:true, session_id:"", created_at:"2026-01-01T00:00:00Z", launch_context:{pane_id:"p_other"}}
        ]';;
      norows)
        jq -n '[]';;
      fallback)
        jq -n --arg sender "${MOCK_SPAWNER_BUS:-dispatcher-rive}" '[
          {name:$sender, joined:true, session_id:"current-session",
           created_at:"2026-01-01T00:00:00Z", launch_context:{pane_id:"p_orch"}},
          {name:"decoy-dir",   tag:"worker", directory:"/elsewhere",
           created_at:"2026-01-01T00:00:00Z", launch_context:{pane_id:"p_98"}},
          {name:"worker-nova", tag:"worker", directory:"/mock/cwd",
           created_at:"2026-01-01T00:00:01Z", launch_context:{pane_id:"p_99"}}
        ]';;
      fallback_ambiguous)
        jq -n --arg sender "${MOCK_SPAWNER_BUS:-dispatcher-rive}" '[
          {name:$sender, joined:true, session_id:"current-session",
           created_at:"2026-01-01T00:00:00Z", launch_context:{pane_id:"p_orch"}},
          {name:"worker-old",  tag:"worker", directory:"/mock/cwd",
           created_at:"2026-01-01T00:00:00Z", launch_context:{pane_id:"p_98"}},
          {name:"worker-nova", tag:"worker", directory:"/mock/cwd",
           created_at:"2026-01-01T00:00:01Z", launch_context:{pane_id:"p_99"}}
        ]';;
      *)
        jq -n --arg sender "${MOCK_SPAWNER_BUS:-dispatcher-rive}" '[
          {name:$sender, joined:true, session_id:"current-session",
           created_at:"2026-01-01T00:00:00Z", launch_context:{pane_id:"p_orch"}}
        ]';;
    esac;;
  "list "*)
    # hcom list <bus_name> — the bus send's target-joined precheck
    printf '%s' "${2:-}" >"$PROBE/list_target"
    jq -n --arg n "${2:-}" '[{name:$n}]';;
  "send "*)
    # hcom send --from <sender> @<bus_name> -- <message>
    printf '%s\n' "$*" >"$PROBE/send_argv"
    sender=""
    args=("$@")
    for ((i = 0; i < ${#args[@]}; i++)); do
      if [[ "${args[$i]}" == "--from" && $((i + 1)) -lt ${#args[@]} ]]; then
        sender="${args[$((i + 1))]}"
        break
      fi
    done
    [[ -n "$sender" ]] || { printf 'mock-hcom-spawn: send missing --from\n' >&2; exit 1; }
    printf '%s' "$sender" >"$PROBE/send_sender"
    [[ "$SCEN" == *_sendfail ]] && exit 1
    printf 'ok\n';;
  "events "*)
    # hcom events --last N --agent <name> --context deliver:<sender> --after <iso>
    # Real hcom emits JSONL (one event object per line, monotone `id`); no
    # match emits nothing. Stateful like mock-hcom: the pre-send snapshot call
    # sees no receipts; post-send polls see a strictly-newer receipt.
    printf '%s\n' "$*" >"$PROBE/events_argv"
    if [[ "$SCEN" != *_queued ]]; then
      if [[ -f "$PROBE/events_polled" ]]; then
        sender="$(cat "$PROBE/send_sender")"
        jq -cn --arg sender "$sender" '{id:42, data:{context:("deliver:"+$sender)}, instance:"worker-rive", type:"status"}'
      else
        : >"$PROBE/events_polled"
      fi
    fi;;
  *)
    printf 'mock-hcom-spawn: unhandled: %s\n' "$*" >&2
    exit 1;;
esac
