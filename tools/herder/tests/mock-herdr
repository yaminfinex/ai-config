#!/usr/bin/env bash
# mock-herdr — a deterministic, hermetic stand-in for the `herdr` CLI, used by
# check-send-contract.sh to exercise the herder send SEND path without a live agent.
#
# It answers exactly the herdr sub-invocations herder send / driver-herdr.sh make:
#   herdr pane list
#   herdr agent list
#   herdr agent read <pane> [flags...]
#   herdr agent send <pane> <message>
#   herdr pane send-keys <pane> Enter
#
# Behaviour is driven by two env vars (set by the harness):
#   MOCK_HERDR_SCENARIO  idle | normal | noenter | busy | modal
#   MOCK_HERDR_STATE     a scratch dir; `agent send` / `send-keys Enter` drop marker
#                        files here so `agent read` / `agent list` can move through
#                        pre-send → buffered → submitted states deterministically.
#
# Pane/terminal topology (matches fixtures/registry.jsonl):
#   term_AAA @ p_10  (label alpha — stored==live, no drift)
#   term_BBB @ p_99  (label beta  — stored p_20, drifted to p_99)

set -euo pipefail

SCEN="${MOCK_HERDR_SCENARIO:-idle}"
STATE="${MOCK_HERDR_STATE:-/tmp/mock-herdr-state}"
mkdir -p "$STATE"

sent()  { [[ -f "$STATE/send" ]]; }
entered() { [[ -f "$STATE/enter" ]]; }
sent_msg() { cat "$STATE/msg" 2>/dev/null || true; }

sig='❯'   # claude sigil (all mock agents are claude)

emit_read() {  # $1 = text
  jq -n --arg t "$1" '{result:{read:{text:$t}}}'
}

# ---- current agent_status for the (single) mock agent ----
current_status() {
  case "$SCEN" in
    busy) printf 'working';;            # already mid-turn the whole time
    normal|modal|bootrace)
      if entered; then printf 'working'; else printf 'idle'; fi;;
    *) printf 'idle';;                  # idle / noenter never flip
  esac
}

# ---- pane text for the current phase ----
current_text() {
  local msg; msg="$(sent_msg)"
  if ! sent; then
    # pre-send phase
    case "$SCEN" in
      modal) printf '⏺ project loaded\nDo you trust the contents of this directory?\n  1. Yes, continue\n%s ' "$sig";;
      bootrace) printf '✳ Starting Claude…\n  esc to interrupt';;   # booting: no ready sigil yet
      *)     printf '⏺ ready\n%s ' "$sig";;
    esac
    return
  fi
  # post-send
  case "$SCEN" in
    bootrace)
      # Boot-race: the paste physically landed, but while claude is still
      # booting the capture keeps returning boot chrome — the composer (and our
      # pasted text) is NOT visible. Only once Enter submits does the pane
      # settle and reveal the transcript. A blind re-paste in this window is the
      # doubling bug; the guard must NOT paste again while the pane is unreadable.
      if entered; then
        printf '⏺ %s\n⏺ working…\n%s ' "$msg" "$sig"
      else
        printf '✳ Starting Claude…\n  esc to interrupt'
      fi;;
    busy)
      # queued: text renders on the input/sigil line and stays there (submitted or not)
      printf '⏺ working on previous turn\n%s %s' "$sig" "$msg";;
    noenter)
      # placed in the buffer, never submitted
      printf '⏺ ready\n%s %s' "$sig" "$msg";;
    *)
      if entered; then
        # submitted: message moved into the transcript, sigil line empty again
        printf '⏺ %s\n⏺ working…\n%s ' "$msg" "$sig"
      else
        # buffered, awaiting Enter
        printf '⏺ ready\n%s %s' "$sig" "$msg"
      fi;;
  esac
}

case "${1:-}" in
  pane)
    case "${2:-}" in
      list)
        jq -n '{result:{panes:[
          {pane_id:"p_10", terminal_id:"term_AAA"},
          {pane_id:"p_99", terminal_id:"term_BBB"}
        ]}}';;
      send-keys)
        # herdr pane send-keys <pane> Enter
        [[ "${4:-}" == "Enter" ]] && : > "$STATE/enter"
        printf '{"result":{"ok":true}}\n';;
      *) printf '{"result":{}}\n';;
    esac;;
  agent)
    case "${2:-}" in
      list)
        jq -n --arg st "$(current_status)" \
          '{result:{agents:[{pane_id:"p_10", agent:"claude", agent_status:$st}]}}';;
      read)
        emit_read "$(current_text)";;
      send)
        # herdr agent send <pane> <message>
        printf '%s' "${4:-}" > "$STATE/msg"
        : > "$STATE/send"
        printf '{"result":{"ok":true}}\n';;
      *) printf '{"result":{}}\n';;
    esac;;
  *)
    printf 'mock-herdr: unhandled: %s\n' "$*" >&2; exit 1;;
esac
