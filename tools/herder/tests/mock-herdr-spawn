#!/usr/bin/env bash
# mock-herdr-spawn — a deterministic, hermetic stand-in for the `herdr` CLI,
# used by check-spawn-contract.sh to exercise the FULL herder spawn path
# (agent start, --new-tab pane move, readiness/modal machine, root-pane close +
# re-resolution for worktrees, prompt delivery via the send leg) without a live session.
#
# It answers exactly the herdr sub-invocations herder spawn (and the herder send
# it delegates prompt delivery to) makes:
#   herdr pane get <pane>
#   herdr agent start <label> [flags...] -- <argv...>
#   herdr pane move <pane> --new-tab [--label <label>]
#   herdr pane list
#   herdr pane close <pane>
#   herdr agent read <pane> [flags...]
#   herdr agent list
#   herdr agent send <pane> <message>
#   herdr pane send-keys <pane> Enter
#   herdr worktree list --cwd <dir> --json
#   herdr worktree create --cwd <dir> --branch <name> [--base REF] --no-focus --json
#
# Behaviour is driven by env vars (set by the harness):
#   MOCK_SPAWN_SCENARIO  ready | modal | modalvis | unknownmodal | polluted_clear
#                        | polluted_still | newtab_movefail | rootguard | startfail
#                        | wtcreatefail | wtstartfail
#       ready     — agent is receptive immediately
#       modal     — a first-run directory-trust modal is open until an Enter
#                   clears it (then the agent is receptive). Modal text shows in
#                   EVERY read source (idealized; kept for back-compat).
#       modalvis  — a first-run trust modal that behaves like the real
#                   alternate-screen overlay: its text appears ONLY for
#                   `--source visible`; `--source recent-unwrapped` reads null,
#                   and agent status is `blocked` until an Enter clears it.
#                   Locks the per-source detection fix.
#       unknownmodal — an UNRECOGNIZED alternate-screen overlay: non-trust text
#                   on `--source visible` only, status `blocked`, never clears.
#                   Exercises the self-healing timeout snippet.
#       polluted_clear — a bash composer starts with stray text; ctrl+u clears it,
#                   then the paste proceeds and reports composer_cleared.
#       polluted_still — a bash composer starts with stray text; ctrl+u is accepted
#                   but does not clear, so paste refuses before typing.
#       newtab_movefail — `pane move <agent> --new-tab` fails, leaving the
#                   agent alive in its original split pane
#       rootguard — the worktree seed root pane reports a terminal_id equal to
#                   the agent's (herder spawn must refuse the root-pane close)
#       startfail — `agent start` fails with a JSON error payload (exit 3)
#       wtcreatefail — `worktree create` fails with a JSON error payload
#                   (exit 3); locks --worktree fail-fast before any pane
#       wtstartfail — `worktree create` succeeds but `agent start` then fails:
#                   locks --worktree's created-but-not-spawned leak report
#       (echoloss, the TASK-024 claude paste-verify race, retired with the
#        paste path itself — TASK-032 moved bus-capable prompts onto hcom.)
#   MOCK_SPAWN_AGENT     claude | codex | bash — reported in `agent list` and
#                        selects the input sigil (❯ / › / $)
#   MOCK_SPAWN_STATE     scratch dir; marker files move the state machine
#                        through modal → ready → buffered → submitted
#   MOCK_PROBE_DIR       probe dir; every MUTATING call appends to calls, and
#                        `agent start` records its full argv (one arg per line)
#                        to agent_start_argv
#
# Pane/terminal topology:
#   p_orch @ term_ORCH   the spawning orchestrator pane (HERDR_PANE_ID)
#   p_50   @ term_AGENT  the agent's pane at launch
#   p_60   @ term_WTROOT the seed root shell of a --worktree workspace (w_WT)
#   p_41   @ term_AGENT  fixture pane after a worktree root close/re-key

set -euo pipefail

SCEN="${MOCK_SPAWN_SCENARIO:-ready}"
AGENT_KIND="${MOCK_SPAWN_AGENT:-claude}"
STATE="${MOCK_SPAWN_STATE:?}"
PROBE="${MOCK_PROBE_DIR:?}"
mkdir -p "$STATE" "$PROBE"

log_call() { printf '%s\n' "$*" >>"$PROBE/calls"; }

sent()          { [[ -f "$STATE/send" ]]; }
entered()       { [[ -f "$STATE/enter" ]]; }
modal_cleared() { [[ -f "$STATE/modal_cleared" ]]; }
composer_cleared() { [[ -f "$STATE/composer_cleared" ]]; }
root_closed()   { [[ -f "$STATE/root_closed" ]]; }
newtab_moved()  { [[ -f "$STATE/newtab_moved" ]]; }
agent_closed()  { [[ -f "$STATE/agent_closed" ]]; }
sent_msg()      { cat "$STATE/msg" 2>/dev/null || true; }

case "$AGENT_KIND" in
  claude) sig='❯';;
  codex)  sig='›';;
  *)      sig='$';;
esac

agent_pane() { if root_closed; then printf 'p_41'; else printf 'p_50'; fi; }

root_term() {
  # rootguard: the worktree seed root pane reports the AGENT's terminal_id, so
  # herder spawn's identity guard must refuse to close it.
  if [[ "$SCEN" == "rootguard" ]]; then printf 'term_AGENT'; else printf 'term_ROOT'; fi
}

agent_tab() { if newtab_moved; then printf 'tab_9'; else printf 'tab_1'; fi; }

modal_open() { [[ "$SCEN" == "modal" ]] && ! modal_cleared; }
# Alternate-screen overlays: text lives on the visible screen only. modalvis
# clears on Enter; unknownmodal never does (an overlay we don't recognize).
modalvis_open()  { [[ "$SCEN" == "modalvis" ]] && ! modal_cleared; }
altscreen_open() { modalvis_open || [[ "$SCEN" == "unknownmodal" ]]; }

# read_source scans a herdr invocation's args for the value after --source.
read_source() {
  local prev=""
  for a in "$@"; do
    [[ "$prev" == "--source" ]] && { printf '%s' "$a"; return; }
    prev="$a"
  done
}

# visible_text is what an alternate-screen overlay paints on the VISIBLE screen
# while it is up — invisible to the recent-unwrapped scrollback stream.
visible_text() {
  if modalvis_open; then
    printf '⏺ starting…\nIs this a project you created or one you trust?\n  ❯ 1. Yes, I trust this folder\n    2. No, exit\n'
    return
  fi
  if [[ "$SCEN" == "unknownmodal" ]]; then
    printf 'Sign in to continue\nPaste your API key to authenticate:\n> \n'
    return
  fi
  current_text
}

current_status() {
  if altscreen_open; then printf 'blocked'; return; fi
  if entered; then printf 'working'; else printf 'idle'; fi
}

current_text() {
  local msg; msg="$(sent_msg)"
  if modal_open; then
    printf '⏺ starting…\nDo you trust the contents of this directory?\n  1. Yes, continue\n%s ' "$sig"
    return
  fi
  if [[ "$SCEN" == "polluted_clear" || "$SCEN" == "polluted_still" ]] && ! composer_cleared && ! sent; then
    printf '⏺ ready\n%s stray draft' "$sig"
    return
  fi
  if ! sent; then
    printf '⏺ ready\n%s ' "$sig"
    return
  fi
  if entered; then
    printf '⏺ %s\n⏺ working…\n%s ' "$msg" "$sig"
  else
    printf '⏺ ready\n%s %s' "$sig" "$msg"
  fi
}

emit_read() { jq -n --arg t "$1" '{result:{read:{text:$t}}}'; }

case "${1:-} ${2:-}" in
  "pane get")
    case "${3:-}" in
      p_orch)     jq -n --arg cwd "${MOCK_SPAWNER_CWD:-/mock/cwd}" '{result:{pane:{pane_id:"p_orch", terminal_id:"term_ORCH", workspace_id:"ws_1", tab_id:"tab_1", foreground_cwd:$cwd}}}';;
      p_60)       jq -n '{result:{pane:{pane_id:"p_60", terminal_id:"term_WTROOT", workspace_id:"w_WT", tab_id:"tab_WT"}}}';;
      p_50|p_41)  if agent_closed; then jq -n '{error:{code:"pane_not_found"}}'; exit 1; fi
                   jq -n --arg p "$(agent_pane)" --arg tab "$(agent_tab)" --arg ws "$(cat "$STATE/agent_workspace" 2>/dev/null || printf ws_1)" '{result:{pane:{pane_id:$p, terminal_id:"term_AGENT", workspace_id:$ws, tab_id:$tab}}}';;
      *)          jq -n '{result:{}}';;
    esac;;
  "workspace list")
    # Read (not logged): serves the workspace validation that the caller-pane
    # anchoring default triggers (HERDR_PANE_ID=p_orch → ws_1) on every spawn.
    # checkout_path lets herder spawn resolve the child's default cwd from the
    # anchored workspace when --cwd is omitted (the documented "current" default).
    jq -n '{result:{workspaces:[{workspace_id:"ws_1", worktree:{checkout_path:"/mock/cwd"}},{workspace_id:"ws_2", worktree:{checkout_path:"/mock/other"}}]}}';;
  "agent start")
    log_call agent start "${3:-}"
    printf '%s\n' "$@" >"$PROBE/agent_start_argv"
    if [[ "$SCEN" == "startfail" || "$SCEN" == "wtstartfail" ]]; then
      jq -n '{error:{code:"agent_placement_not_found", message:"mock start failure"}}'
      exit 3
    fi
    # tab_id/workspace_id/cwd echo explicit placements, else the defaults
    # (identical output for every pre-worktree scenario, which always sends
    # --workspace ws_1 and --cwd /mock/cwd or nothing).
    tab="tab_1"; ws="ws_1"; cwd="/mock/cwd"
    prev=""
    for a in "$@"; do
      [[ "$prev" == "--tab" ]] && tab="$a"
      [[ "$prev" == "--workspace" ]] && ws="$a"
      [[ "$prev" == "--cwd" ]] && cwd="$a"
      prev="$a"
    done
    printf '%s' "$ws" >"$STATE/agent_workspace"
    jq -n --arg tab "$tab" --arg ws "$ws" --arg cwd "$cwd" \
      '{result:{agent:{pane_id:"p_50", workspace_id:$ws, tab_id:$tab,
                       terminal_id:"term_AGENT", cwd:$cwd},
                type:"agent_started"}}';;
  "pane move")
    log_call "$@"
    if [[ "$SCEN" == "newtab_movefail" ]]; then
      jq -n '{error:{code:"pane_move_failed", message:"mock pane move failure"}}'
      exit 5
    fi
    : > "$STATE/newtab_moved"
    jq -n '{result:{type:"pane_moved", pane:{pane_id:"p_50", workspace_id:"ws_1", tab_id:"tab_9", terminal_id:"term_AGENT"}}}';;
  "pane list")
    if ! root_closed; then
      jq -n --arg p "$(agent_pane)" '{result:{panes:[
        {pane_id:"p_orch", terminal_id:"term_ORCH"},
        {pane_id:$p,       terminal_id:"term_AGENT"}
      ]}}'
    else
      jq -n --arg p "$(agent_pane)" '{result:{panes:[
        {pane_id:"p_orch", terminal_id:"term_ORCH"},
        {pane_id:$p,       terminal_id:"term_AGENT"}
      ]}}'
    fi;;
  "pane close")
    log_call "$@"
    [[ "${3:-}" == "p_60" ]] && : > "$STATE/root_closed"
    [[ "${3:-}" == "p_50" || "${3:-}" == "p_41" ]] && : > "$STATE/agent_closed"
    jq -n --arg pane "${3:-}" '{result:{type:"closed", pane_id:$pane}}';;
  "agent read")
    if altscreen_open; then
      # Overlay is up: only the visible source can see it; the scrollback
      # (recent-unwrapped) reads null, exactly as on a live boot trust modal.
      if [[ "$(read_source "$@")" == "visible" ]]; then
        emit_read "$(visible_text)"
      else
        emit_read ""
      fi
    else
      emit_read "$(current_text)"
    fi;;
  "agent list")
    jq -n --arg p "$(agent_pane)" --arg a "$AGENT_KIND" --arg st "$(current_status)" \
      '{result:{agents:[{pane_id:$p, terminal_id:"term_AGENT", agent:$a, agent_status:$st}]}}';;
  "agent send")
    log_call "$@"
    printf '%s' "${4:-}" >"$STATE/msg"
    : > "$STATE/send"
    printf '{"result":{"ok":true}}\n';;
  "pane send-keys")
    log_call "$@"
    if [[ "${4:-}" == "Enter" ]]; then
      # modal/modalvis clear on Enter; unknownmodal never does (it stays wedged).
      if modal_open || modalvis_open; then
        : > "$STATE/modal_cleared"
      elif sent; then
        : > "$STATE/enter"
      fi
    elif [[ "${4:-}" == "ctrl+u" && "$SCEN" == "polluted_clear" ]]; then
      : > "$STATE/composer_cleared"
    fi
    printf '{"result":{"ok":true}}\n';;
  "worktree list")
    # Read (not logged): serves --worktree's source-repo resolution — the
    # parent checkout `worktree create` must be pointed at.
    jq -n '{result:{source:{repo_root:"/mock/src", source_checkout_path:"/mock/src"}}}';;
  "worktree create")
    log_call "$@"
    if [[ "$SCEN" == "wtcreatefail" ]]; then
      jq -n '{error:{code:"worktree_create_failed", message:"mock worktree create failure (branch exists)"}}'
      exit 3
    fi
    jq -n '{result:{type:"worktree_created",
      workspace:{workspace_id:"w_WT", label:"task-foo",
                 worktree:{checkout_path:"/mock/wt", repo_root:"/mock/src"}},
      tab:{tab_id:"tab_WT", workspace_id:"w_WT"},
      root_pane:{pane_id:"p_60", terminal_id:"term_WTROOT", workspace_id:"w_WT"},
      worktree:{branch:"task/foo", path:"/mock/wt", open_workspace_id:"w_WT"}}}';;
  *)
    printf 'mock-herdr-spawn: unhandled: %s\n' "$*" >&2
    exit 64;;
esac
