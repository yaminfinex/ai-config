#!/usr/bin/env bash
# mock-hcom — a deterministic, hermetic stand-in for the `hcom` CLI, used by
# check-hcom-contract.sh to exercise the hcom delivery driver without a live bus.
#
# It answers exactly the hcom sub-invocations driver-hcom.sh makes:
#   hcom list <bus_name>                                  → joined? (exit 0/1)
#   hcom send --from <sender> @<bus_name> -- <message>    → deliver (exit 0/1)
#   hcom events --last N --agent <name> --context deliver:<sender> --after <iso>  → ack array
#     (receipts land on the RECEIVER instance with context deliver:<SENDER>)
#
# Behaviour is driven by env vars (set by the harness):
#   MOCK_HCOM_SCENARIO  delivered | queued | stalereceipt | notjoined | sendfail
#   MOCK_HCOM_PROBE     a scratch dir; every invocation records the effective
#                       HCOM_DIR and (for send) the full argv, so the test can
#                       assert bus scoping + recipient addressing.
#
# It records the HCOM_DIR it was invoked under on EVERY call, proving the driver
# scoped the send to the peer's recorded team bus.

set -euo pipefail

SCEN="${MOCK_HCOM_SCENARIO:-delivered}"
PROBE="${MOCK_HCOM_PROBE:-/tmp/mock-hcom-probe}"
mkdir -p "$PROBE"

# Record the effective bus dir on every call (last write wins; all calls in one
# hcom_send share the same scoped HCOM_DIR, so this is stable within a send).
printf '%s' "${HCOM_DIR:-<unset>}" > "$PROBE/hcom_dir"

case "${1:-}" in
  list)
    # hcom list <bus_name>
    printf '%s' "${2:-}" > "$PROBE/list_target"
    [[ "$SCEN" == "notjoined" ]] && exit 1
    jq -n --arg n "${2:-}" '[{name:$n, joined:true}]'
    exit 0
    ;;
  send)
    # hcom send --from <sender> @<bus_name> -- <message>
    printf '%s\n' "$*" > "$PROBE/send_argv"
    [[ "$SCEN" == "sendfail" ]] && exit 1
    printf 'ok\n'
    exit 0
    ;;
  events)
    # hcom events --last N --agent <name> --context deliver:<sender> --after <iso>
    # Real hcom emits JSONL (one event object per line, monotone `id`), not a
    # JSON array; no match emits nothing.
    printf '%s\n' "$*" > "$PROBE/events_argv"
    case "$SCEN" in
      delivered)
        # Stateful: the pre-send snapshot (first call) sees no receipts; the
        # post-send polls see THIS send's receipt, id strictly newer than the
        # snapshot — mirrors a live instant wake.
        if [[ -f "$PROBE/events_polled" ]]; then
          jq -cn '{id:42, data:{context:"deliver:orchestrator"}, instance:"receiver", type:"status"}'
        else
          : > "$PROBE/events_polled"
        fi;;
      stalereceipt)
        # A receipt from a PREVIOUS same-sender send sits inside the backdated
        # window on EVERY call: the snapshot pins id 41 and nothing strictly
        # newer ever appears — verify must NOT claim delivered (codex P2).
        jq -cn '{id:41, data:{context:"deliver:orchestrator"}, instance:"receiver", type:"status"}';;
    esac
    exit 0
    ;;
  *)
    printf 'mock-hcom: unhandled: %s\n' "$*" >&2
    exit 1
    ;;
esac
