#!/bin/sh
# Open VS Code at a path (default: focused herdr pane's cwd). Dual-mode:
#
#   - laptop: config sets VSC_CODE_BIN -> exec that binary directly.
#   - remote: config has no VSC_CODE_BIN -> curl the tunneled laptop opener,
#     which then runs `code --remote ssh-remote+<host> <path>` locally.
#
# Wired up via herdr [[keys.command]] on either side; $HERDR_ACTIVE_PANE_CWD
# is set by herdr for custom-command shells.

set -eu

config="${VSC_OPENER_CONFIG:-$HOME/.config/vsc-opener/config}"

if [ ! -f "$config" ]; then
  echo "vsc-open: config not found: $config" >&2
  exit 1
fi

# shellcheck disable=SC1090
. "$config"

path="${1:-${HERDR_ACTIVE_PANE_CWD:-${PWD:-}}}"

if [ -z "$path" ]; then
  echo "vsc-open: no path (pass an arg, or set HERDR_ACTIVE_PANE_CWD)" >&2
  exit 1
fi

# Laptop mode: VSC_CODE_BIN means VS Code lives on this box.
if [ -n "${VSC_CODE_BIN:-}" ]; then
  exec "$VSC_CODE_BIN" "$path"
fi

# Remote mode: hand off to the laptop via the reverse-tunneled opener.
: "${VSC_OPEN_TOKEN:?VSC_OPEN_TOKEN missing in config}"
: "${VSC_OPEN_PORT:=36221}"

curl -fsS -G \
  --max-time 5 \
  --data-urlencode "token=$VSC_OPEN_TOKEN" \
  --data-urlencode "path=$path" \
  "http://127.0.0.1:${VSC_OPEN_PORT}/open" >/dev/null
